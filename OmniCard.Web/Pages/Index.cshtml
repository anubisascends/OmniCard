@page
@model OmniCard.Web.Pages.IndexModel
@{
    ViewData["Title"] = "OmniCard Collection";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="/css/site.css"/>
</head>
<body>
    <header>
        <h1>OmniCard Collection</h1>
        <div class="nav-links">
            <a href="/">Home</a>
            <a href="/decklist">Decklist Check</a>
        </div>
    </header>
    <main>
        <form method="get" class="search-bar" id="searchForm">
            <input type="text" name="q" id="searchInput" value="@Model.Q" placeholder="Search cards... (e.g. lightning, set:tmt, cn:002)" />
            <select name="game" id="gameFilter" onchange="this.form.submit()">
                <option value="">All Games</option>
                <option value="mtg" selected="@(Model.Game == "mtg" ? "selected" : null)">Magic: The Gathering</option>
                <option value="optcg" selected="@(Model.Game == "optcg" ? "selected" : null)">One Piece</option>
            </select>
            <button type="submit">Search</button>
            @if (Model.IsSearchActive || !string.IsNullOrWhiteSpace(Model.Game))
            {
                <a href="/" class="clear-link" id="clearLink">Clear</a>
            }
        </form>

        @if (Model.IsSearchActive)
        {
            <h2>Search Results (@Model.SearchResults.Count)</h2>
            @if (Model.SearchResults.Count == 0)
            {
                <p class="empty">No cards found.</p>
            }
            else
            {
                <table>
                    <thead>
                        <tr>
                            <th class="sortable" data-sort-numeric>Qty</th>
                            <th class="sortable">Name</th>
                            <th class="sortable">Set</th>
                            <th class="sortable">#</th>
                            <th class="sortable">Rarity</th>
                            <th class="sortable">Color</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.SearchResults)
                        {
                            <tr>
                                <td>@r.Quantity</td>
                                <td><a href="/card/@r.Id">@r.Name</a></td>
                                <td>@r.SetCode</td>
                                <td>@r.Number</td>
                                <td>@r.Rarity</td>
                                <td>@(r.Color ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        }
        else
        {
            <h2>Storage Locations</h2>
            @if (Model.Containers.Count == 0)
            {
                <p class="empty">No storage locations found.</p>
            }
            else
            {
                @foreach (var group in Model.ContainersByType)
                {
                    var sectionKey = group.Key.ToString();
                    var totalCards = group.Sum(c => c.CardCount);
                    <details class="location-section" data-section="@sectionKey">
                        <summary>
                            @(group.First().TypeDisplay) <span class="count">&times;@group.Count() (@totalCards cards)</span>
                        </summary>
                        <table>
                            <thead>
                                <tr>
                                    <th class="sortable">Name</th>
                                    <th class="sortable" data-sort-numeric>Cards</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var c in group)
                                {
                                    <tr>
                                        <td><a href="/location/@c.Id">@c.Name</a></td>
                                        <td>@c.CardCount</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </details>
                }
            }
        }
    </main>

    <script src="/js/table-sort.js"></script>
    <script>
        (function() {
            var STORE_KEY = 'omnicard_prefs';

            function loadPrefs() {
                try { return JSON.parse(localStorage.getItem(STORE_KEY)) || {}; }
                catch { return {}; }
            }

            function savePrefs(prefs) {
                localStorage.setItem(STORE_KEY, JSON.stringify(prefs));
            }

            var prefs = loadPrefs();

            // Restore section open/closed state
            document.querySelectorAll('details.location-section').forEach(function(el) {
                var key = el.dataset.section;
                if (prefs.sections && prefs.sections[key] === false) {
                    el.removeAttribute('open');
                } else {
                    el.setAttribute('open', '');
                }
                el.addEventListener('toggle', function() {
                    var p = loadPrefs();
                    if (!p.sections) p.sections = {};
                    p.sections[key] = el.open;
                    savePrefs(p);
                });
            });

            // Save search and game filter on form submit
            var form = document.getElementById('searchForm');
            if (form) {
                form.addEventListener('submit', function() {
                    var p = loadPrefs();
                    p.game = document.getElementById('gameFilter').value;
                    p.q = document.getElementById('searchInput').value;
                    savePrefs(p);
                });

                // Also save on game filter change (auto-submit)
                document.getElementById('gameFilter').addEventListener('change', function() {
                    var p = loadPrefs();
                    p.game = this.value;
                    p.q = document.getElementById('searchInput').value;
                    savePrefs(p);
                });
            }

            // Clear prefs when Clear link is clicked
            var clearLink = document.getElementById('clearLink');
            if (clearLink) {
                clearLink.addEventListener('click', function() {
                    var p = loadPrefs();
                    delete p.game;
                    delete p.q;
                    savePrefs(p);
                });
            }

            // On first load with no query params, restore from prefs
            var params = new URLSearchParams(window.location.search);
            if (!params.has('q') && !params.has('game') && (prefs.game || prefs.q)) {
                var url = '/?';
                var parts = [];
                if (prefs.q) parts.push('q=' + encodeURIComponent(prefs.q));
                if (prefs.game) parts.push('game=' + encodeURIComponent(prefs.game));
                if (parts.length > 0) {
                    window.location.replace('/?' + parts.join('&'));
                }
            }
        })();
    </script>
</body>
</html>
