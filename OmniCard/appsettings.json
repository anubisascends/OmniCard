{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ]
  },
  "Display": {
    "CardDetailFontSize": 14,
    "Theme": "Dark"
  },
  "eBay": {
    "AppId": "",
    "CertId": "",
    "DevId": "",
    "RuName": "",
    "Environment": "sandbox"
  },
  "Scryfall": {
    "Languages": ["en"]
  }
}
