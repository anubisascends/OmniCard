<Window x:Class="OmniCard.Views.MovementHistory.MovementHistoryView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:OmniCard.Views.MovementHistory"
        xmlns:conv="clr-namespace:OmniCard.Controls.Converters;assembly=OmniCard.Controls"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Title="Movement History" Height="600" Width="900"
        MinHeight="400" MinWidth="640"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        FontFamily="{StaticResource AppFont}">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Filter bar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Type:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <ComboBox Width="120" VerticalAlignment="Center" Margin="0,0,16,0"
                      ItemsSource="{Binding TypeOptions}"
                      SelectedItem="{Binding SelectedTypeOption}"/>

            <TextBlock Text="Period:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <RadioButton Content="All Time" GroupName="Period" VerticalAlignment="Center" Margin="0,0,10,0"
                         IsChecked="{Binding Period, Converter={conv:EnumBoolConverter}, ConverterParameter=AllTime}"/>
            <RadioButton Content="This Year" GroupName="Period" VerticalAlignment="Center" Margin="0,0,10,0"
                         IsChecked="{Binding Period, Converter={conv:EnumBoolConverter}, ConverterParameter=ThisYear}"/>
            <RadioButton Content="This Month" GroupName="Period" VerticalAlignment="Center" Margin="0,0,16,0"
                         IsChecked="{Binding Period, Converter={conv:EnumBoolConverter}, ConverterParameter=ThisMonth}"/>

            <TextBlock Text="Product:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox Width="220" VerticalAlignment="Center" Margin="0,0,8,0"
                     Text="{Binding ProductQuery, UpdateSourceTrigger=PropertyChanged}">
                <TextBox.InputBindings>
                    <KeyBinding Key="Return" Command="{Binding RefreshCommand}"/>
                </TextBox.InputBindings>
            </TextBox>

            <Button Content="Refresh" Command="{Binding RefreshCommand}" Padding="12,4"/>
        </StackPanel>

        <ProgressBar Grid.Row="1"
                     Height="4"
                     Margin="0,0,0,8"
                     IsIndeterminate="True"
                     Visibility="{Binding IsBusy, Converter={conv:BoolToVisibilityConverter}}"/>

        <!-- Ledger grid -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Movements}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  EnableRowVirtualization="True"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Date" Binding="{Binding Timestamp, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="140"/>
                <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="80"/>
                <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="*"/>
                <DataGridTextColumn Header="Game" Binding="{Binding Game}" Width="80"/>
                <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="60"/>
                <DataGridTextColumn Header="Value" Binding="{Binding UnitValue, StringFormat='{}{0:C2}', TargetNullValue=''}" Width="90"/>
                <DataGridTextColumn Header="Note" Binding="{Binding Note}" Width="200"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Empty state -->
        <TextBlock Grid.Row="2"
                   Text="No movements match the current filters."
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="16"
                   FontStyle="Italic"
                   Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
                   IsHitTestVisible="False">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Movements.Count}" Value="0">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <TextBlock Grid.Row="3"
                   Text="{Binding StatusMessage}"
                   Margin="0,8,0,0"
                   FontStyle="Italic"
                   Foreground="OrangeRed"
                   Visibility="{Binding StatusMessage, Converter={conv:StringToVisibilityConverter}}"/>

        <Grid Grid.Row="4" Margin="0,8,0,0">
            <TextBlock Text="{Binding Movements.Count, StringFormat='{}{0} movement(s)'}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"/>
            <Button Content="Close"
                    IsCancel="True"
                    Padding="16,6"
                    FontWeight="SemiBold"
                    HorizontalAlignment="Right"
                    Click="CloseButton_Click"/>
        </Grid>
    </Grid>
</Window>
