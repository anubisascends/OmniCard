<Window x:Class="OmniCard.Views.Splash.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        SizeToContent="WidthAndHeight"
        Topmost="True"
        ShowInTaskbar="False">

    <Border Background="#FF1E1E2E"
            CornerRadius="12"
            BorderBrush="#FF4CAF50"
            BorderThickness="1"
            Padding="40,30"
            MinWidth="400">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.5" ShadowDepth="0" Color="Black"/>
        </Border.Effect>

        <StackPanel HorizontalAlignment="Center">
            <!-- Logo -->
            <Image Source="/Resources/Images/OmniCard_Logo.png"
                   Width="128" Height="128"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   Margin="0,0,0,16"/>

            <!-- App name -->
            <TextBlock Text="OmniCard"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,24"/>

            <!-- Progress bar -->
            <ProgressBar x:Name="SplashProgress"
                         IsIndeterminate="True"
                         Height="3"
                         Foreground="#FF4CAF50"
                         Background="#FF2E2E3E"
                         BorderThickness="0"
                         Margin="0,0,0,12"/>

            <!-- Status message -->
            <TextBlock x:Name="StatusText"
                       Text="Starting..."
                       FontSize="13"
                       Foreground="#FFAAAAAA"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Border>
</Window>
