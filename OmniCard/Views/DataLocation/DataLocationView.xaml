<Window x:Class="OmniCard.Views.DataLocation.DataLocationView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OmniCard.Views.DataLocation"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance {x:Type local:DataLocationView}}"
        Title="Data Location" Height="340" Width="520"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        FontFamily="{StaticResource AppFont}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:InvertBooleanConverter x:Key="InvertBool"/>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Current path -->
        <TextBlock Grid.Row="0" Text="Data Location" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,12"/>

        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Current path:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox Grid.Column="1" Text="{Binding ViewModel.CurrentPath, Mode=OneWay}"
                     IsReadOnly="True" Margin="0,0,8,0" VerticalAlignment="Center"/>
            <Button Grid.Column="2" Content="Browse..." Command="{Binding ViewModel.BrowseCommand}"
                    Padding="12,4" IsEnabled="{Binding ViewModel.IsMigrating, Converter={StaticResource InvertBool}}"/>
        </Grid>

        <!-- Status -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Status:" Margin="0,0,8,0" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding ViewModel.StatusText}" VerticalAlignment="Center" FontWeight="SemiBold"/>
        </StackPanel>

        <!-- Pending migration info -->
        <Border Grid.Row="3" Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                CornerRadius="4" Padding="12" Margin="0,0,0,8"
                Visibility="{Binding ViewModel.IsMigrationPending, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                    <Run Text="Target: "/>
                    <Run Text="{Binding ViewModel.PendingPath, Mode=OneWay}" FontWeight="SemiBold"/>
                </TextBlock>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Migrate Now" Command="{Binding ViewModel.MigrateCommand}"
                            Padding="12,4" Margin="0,0,8,0"
                            IsEnabled="{Binding ViewModel.IsMigrating, Converter={StaticResource InvertBool}}"/>
                    <Button Content="Cancel" Command="{Binding ViewModel.CancelMigrationCommand}" Padding="12,4"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Migration progress -->
        <Border Grid.Row="4" Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                CornerRadius="4" Padding="12" Margin="0,0,0,8"
                Visibility="{Binding ViewModel.IsMigrating, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <ProgressBar Value="{Binding ViewModel.MigrationProgress}" Minimum="0" Maximum="100"
                             Height="20" Margin="0,0,0,8"/>
                <TextBlock Text="{Binding ViewModel.MigrationStatusText}" TextTrimming="CharacterEllipsis"/>
                <Button Content="Cancel Migration" Command="{Binding ViewModel.CancelMigrationCommand}"
                        Padding="12,4" Margin="0,8,0,0" HorizontalAlignment="Left"/>
            </StackPanel>
        </Border>

        <!-- Data summary -->
        <TextBlock Grid.Row="5" Text="{Binding ViewModel.DataSummary}" VerticalAlignment="Bottom"
                   Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}" Margin="0,0,0,8"/>

        <!-- Close button -->
        <Button Grid.Row="6" Content="Close" Command="{Binding ViewModel.CloseCommand}"
                HorizontalAlignment="Right" Padding="16,4"/>
    </Grid>
</Window>
