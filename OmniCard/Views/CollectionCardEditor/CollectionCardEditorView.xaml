<Window x:Class="OmniCard.Views.CollectionCardEditor.CollectionCardEditorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OmniCard.Views.CollectionCardEditor"
        xmlns:controls="clr-namespace:OmniCard.Views.Controls"
        xmlns:helpers="clr-namespace:OmniCard.Helpers"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        d:DataContext="{d:DesignInstance {x:Type local:CollectionCardEditorView}}"
        Title="Edit Collection Card" Height="900" Width="800"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        FontFamily="{StaticResource AppFont}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Card Info (read-only) -->
        <Border Background="{DynamicResource MaterialDesign.Brush.Card.Background}" CornerRadius="4" Padding="8" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/><RowDefinition/><RowDefinition/>
                </Grid.RowDefinitions>

                <TextBlock Text="Name:" FontWeight="SemiBold" Margin="0,2,8,2"/>
                <TextBlock Grid.Column="1" Text="{Binding ViewModel.CardName}" Margin="0,2" Grid.ColumnSpan="3"/>

                <TextBlock Grid.Row="1" Text="Set:" FontWeight="SemiBold" Margin="0,2,8,2"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ViewModel.SetInfo}" Margin="0,2"/>
                <TextBlock Grid.Row="1" Grid.Column="2" Text="Number:" FontWeight="SemiBold" Margin="12,2,8,2"/>
                <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding ViewModel.CardNumber}" Margin="0,2"/>

                <TextBlock Grid.Row="2" Text="Rarity:" FontWeight="SemiBold" Margin="0,2,8,2"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ViewModel.Rarity}" Margin="0,2"/>
                <TextBlock Grid.Row="2" Grid.Column="2" Text="Game:" FontWeight="SemiBold" Margin="12,2,8,2"/>
                <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding ViewModel.GameName}" Margin="0,2"/>
            </Grid>
        </Border>

        <!-- Printing selector -->
        <Border Grid.Row="1" Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                CornerRadius="4" Padding="8" Margin="0,0,0,8"
                Visibility="{Binding ViewModel.ShowPrintingSelector, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Text="Printing" FontWeight="SemiBold" FontSize="11"
                           Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}" Margin="0,0,0,4"/>
                <ComboBox ItemsSource="{Binding ViewModel.AvailablePrintings}"
                          SelectedItem="{Binding ViewModel.SelectedPrinting}"
                          MaxDropDownHeight="300">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="2">
                                <Border Width="14" Height="14" Margin="0,0,6,0"
                                    helpers:SetSymbol.SetCode="{Binding SetCode}"
                                    helpers:SetSymbol.Rarity="{Binding Rarity}"/>
                                <TextBlock Text="{Binding SetName}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding CollectorNumber, StringFormat='#{0}'}"
                                       Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
                                       VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
        </Border>

        <!-- Images -->
        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <StackPanel HorizontalAlignment="Center">
                <Image Source="{Binding ViewModel.ScanImage}" Stretch="Fill"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <!-- Scan flipper for stacked cards -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0"
                            Visibility="{Binding ViewModel.IsStacked, Converter={StaticResource BoolToVis}}">
                    <Button Content="&lt;" Padding="6,0"
                            Command="{Binding ViewModel.PreviousScanCommand}"
                            IsEnabled="{Binding ViewModel.CanPreviousScan}"
                            Style="{StaticResource MaterialDesignFlatButton}"/>
                    <TextBlock Text="{Binding ViewModel.ScanImageLabel}"
                               VerticalAlignment="Center" Margin="6,0"
                               Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
                               FontStyle="Italic"/>
                    <Button Content="&gt;" Padding="6,0"
                            Command="{Binding ViewModel.NextScanCommand}"
                            IsEnabled="{Binding ViewModel.CanNextScan}"
                            Style="{StaticResource MaterialDesignFlatButton}"/>
                </StackPanel>
                <!-- Single card label -->
                <TextBlock Text="Scan" HorizontalAlignment="Center" FontStyle="Italic"
                           Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}" Margin="0,4,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ViewModel.IsStacked}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>

            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                <Image Source="{Binding ViewModel.ApiImage}" Stretch="Fill"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock Text="Card Art" HorizontalAlignment="Center" FontStyle="Italic" Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}" Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Editable Fields -->
        <Border Grid.Row="3" Background="{DynamicResource MaterialDesign.Brush.Card.Background}" CornerRadius="4" Padding="8" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Condition:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox Grid.Column="1" SelectedItem="{Binding ViewModel.Condition}"
                          VerticalAlignment="Center" Margin="0,0,12,0">
                    <sys:String xmlns:sys="clr-namespace:System;assembly=System.Runtime">NM</sys:String>
                    <sys:String xmlns:sys="clr-namespace:System;assembly=System.Runtime">LP</sys:String>
                    <sys:String xmlns:sys="clr-namespace:System;assembly=System.Runtime">MP</sys:String>
                    <sys:String xmlns:sys="clr-namespace:System;assembly=System.Runtime">HP</sys:String>
                    <sys:String xmlns:sys="clr-namespace:System;assembly=System.Runtime">D</sys:String>
                </ComboBox>

                <CheckBox Grid.Column="2" Content="Foil"
                          IsChecked="{Binding ViewModel.IsFoil}"
                          VerticalAlignment="Center" Margin="0,0,12,0"/>

                <TextBlock Grid.Column="3" Text="Purchase $:" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox Grid.Column="4" Width="80"
                         Text="{Binding ViewModel.PurchasePrice, TargetNullValue='', UpdateSourceTrigger=LostFocus}"
                         VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Location -->
        <GroupBox Header="Location" Grid.Row="4" Margin="0,0,0,8">
            <StackPanel Margin="4">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="Container:" VerticalAlignment="Center" Margin="0,0,8,0" Width="70"/>
                    <ComboBox ItemsSource="{Binding ViewModel.AvailableContainers}"
                              SelectedItem="{Binding ViewModel.SelectedContainer}"
                              DisplayMemberPath="Name" Width="200" Margin="0,0,8,0"/>
                    <Button Content="Move to Bulk" Command="{Binding ViewModel.MoveToBulkCommand}" Padding="8,2"/>
                </StackPanel>

                <!-- Binder position fields -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4"
                            Visibility="{Binding ViewModel.ShowBinderFields, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Page:" VerticalAlignment="Center" Margin="0,0,8,0" Width="70"/>
                    <TextBox Text="{Binding ViewModel.Page, TargetNullValue='', UpdateSourceTrigger=LostFocus}"
                             Width="60" Margin="0,0,16,0"/>
                    <TextBlock Text="Slot:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Text="{Binding ViewModel.Slot, TargetNullValue='', UpdateSourceTrigger=LostFocus}"
                             Width="60"/>
                </StackPanel>

                <!-- Box section field -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4"
                            Visibility="{Binding ViewModel.ShowBoxFields, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Section:" VerticalAlignment="Center" Margin="0,0,8,0" Width="70"/>
                    <TextBox Text="{Binding ViewModel.Section, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"
                             Width="200"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <!-- Reassign Card Section -->
        <controls:CardSearchControl Grid.Row="5" Margin="0,0,0,8"
            Header="Reassign Card"
            SearchQuery="{Binding ViewModel.SearchQuery, Mode=TwoWay}"
            SearchResults="{Binding ViewModel.SearchResults}"
            SelectedResult="{Binding ViewModel.SelectedSearchResult, Mode=TwoWay}"
            SearchCommand="{Binding ViewModel.SearchCommand}"
            AssignCommand="{Binding ViewModel.AssignCardCommand}"
            ResultsMaxHeight="150"/>

        <!-- Action Buttons -->
        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Apply to all checkbox (only visible for stacked cards) -->
            <CheckBox Content="Apply to all copies in stack"
                      IsChecked="{Binding ViewModel.ApplyToAll}"
                      VerticalAlignment="Center"
                      Visibility="{Binding ViewModel.IsStacked, Converter={StaticResource BoolToVis}}"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Content="Delete" Command="{Binding ViewModel.DeleteCommand}"
                        Padding="16,6" Margin="0,0,8,0" Foreground="Red"/>
                <Button Content="Cancel" Click="OnCancel" IsCancel="True" Padding="16,6" Margin="0,0,8,0"/>
                <Button Content="Save" Command="{Binding ViewModel.SaveCommand}"
                        Padding="16,6" FontWeight="SemiBold"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
