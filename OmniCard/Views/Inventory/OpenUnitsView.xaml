<Window x:Class="OmniCard.Views.Inventory.OpenUnitsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:OmniCard.Views.Inventory"
        xmlns:conv="clr-namespace:OmniCard.Controls.Converters;assembly=OmniCard.Controls"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Title="Open Units" Height="380" Width="420"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        FontFamily="{StaticResource AppFont}">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding ViewModel.ProductName}" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,8"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Lot:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,4,8,4"/>
            <ComboBox Grid.Column="1" Margin="0,4"
                      ItemsSource="{Binding ViewModel.Lots}"
                      SelectedItem="{Binding ViewModel.SelectedLot}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock>
                            <Run Text="{Binding Quantity, Mode=OneWay}"/>
                            <Run Text=" unit(s) — "/>
                            <Run Text="{Binding AcquisitionDate, StringFormat=d, Mode=OneWay}"/>
                            <Run Text=" — $"/>
                            <Run Text="{Binding UnitCost, StringFormat=F2, TargetNullValue='0.00', Mode=OneWay}"/>
                        </TextBlock>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock Grid.Row="1" Text="Quantity to open:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,4,8,4"/>
            <TextBox Grid.Row="1" Grid.Column="1" Margin="0,4"
                     Text="{Binding ViewModel.Quantity, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="2" Text="Note:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,4,8,4"/>
            <TextBox Grid.Row="2" Grid.Column="1" Margin="0,4"
                     Text="{Binding ViewModel.Note, UpdateSourceTrigger=PropertyChanged}"/>
        </Grid>

        <TextBlock Grid.Row="2" Text="{Binding ViewModel.ValidationMessage}"
                   Foreground="Red" Margin="0,4,0,0"
                   Visibility="{Binding ViewModel.ValidationMessage, Converter={conv:NullToVisibilityConverter}}"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Command="{Binding ViewModel.CancelCommand}"
                    IsCancel="True" Padding="16,6" Margin="0,0,8,0"/>
            <Button Content="Open" Command="{Binding ViewModel.ConfirmCommand}"
                    IsDefault="True" Padding="16,6" FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</Window>
