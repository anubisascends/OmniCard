<Window x:Class="OmniCard.Views.Inventory.AddLotView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:OmniCard.Views.Inventory"
        xmlns:conv="clr-namespace:OmniCard.Controls.Converters;assembly=OmniCard.Controls"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Title="Add Lot" Height="380" Width="420"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        FontFamily="{StaticResource AppFont}">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding ViewModel.ProductName}" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,8"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Quantity:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,4,8,4"/>
            <TextBox Grid.Column="1" Margin="0,4"
                     Text="{Binding ViewModel.Quantity, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="1" Text="Unit Cost $:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,4,8,4"/>
            <TextBox Grid.Row="1" Grid.Column="1" Margin="0,4"
                     Text="{Binding ViewModel.UnitCost, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="2" Text="Location:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,4,8,4"/>
            <ComboBox Grid.Row="2" Grid.Column="1" Margin="0,4"
                      ItemsSource="{Binding ViewModel.AvailableContainers}"
                      SelectedItem="{Binding ViewModel.SelectedContainer}"
                      DisplayMemberPath="Name"/>

            <TextBlock Grid.Row="3" Text="Source:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,4,8,4"/>
            <TextBox Grid.Row="3" Grid.Column="1" Margin="0,4"
                     Text="{Binding ViewModel.Source, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="4" Text="Date:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,4,8,4"/>
            <DatePicker Grid.Row="4" Grid.Column="1" Margin="0,4"
                        SelectedDate="{Binding ViewModel.AcquisitionDate}"/>
        </Grid>

        <TextBlock Grid.Row="2" Text="{Binding ViewModel.ValidationMessage}"
                   Foreground="Red" Margin="0,4,0,0"
                   Visibility="{Binding ViewModel.ValidationMessage, Converter={conv:NullToVisibilityConverter}}"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Command="{Binding ViewModel.CancelCommand}"
                    IsCancel="True" Padding="16,6" Margin="0,0,8,0"/>
            <Button Content="Add" Command="{Binding ViewModel.ConfirmCommand}"
                    IsDefault="True" Padding="16,6" FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</Window>
