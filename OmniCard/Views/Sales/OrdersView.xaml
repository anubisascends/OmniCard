<UserControl x:Class="OmniCard.Views.Sales.OrdersView"
             x:Name="OrdersRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:OmniCard.Views.Sales"
             xmlns:conv="clr-namespace:OmniCard.Controls.Converters;assembly=OmniCard.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance {x:Type local:OrdersViewModel}}"
             Loaded="OrdersView_OnLoaded">

    <UserControl.Resources>
        <!-- Card container: strip the default ListBoxItem chrome so the card Border is the whole
             visual; show a primary outline when the card is selected. -->
        <Style x:Key="CardItemContainerStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="wrap" CornerRadius="8" BorderThickness="2" BorderBrush="Transparent">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="wrap" Property="BorderBrush"
                                        Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Jira-style order card, shared by all four columns. Accent stripe + channel badge come
             from the bound Order; drag handlers + context menu are on the card Border. -->
        <DataTemplate x:Key="OrderCardTemplate">
            <Border CornerRadius="6" Margin="0,0,0,8" Cursor="Hand"
                    Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                    BorderThickness="1" BorderBrush="Transparent"
                    PreviewMouseLeftButtonDown="Card_MouseDown"
                    PreviewMouseMove="Card_MouseMove" Tag="{Binding}">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="6" ShadowDepth="1" Direction="270" Opacity="0.28" Color="Black"/>
                </Border.Effect>
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Border.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Cancel order"
                                  Command="{Binding DataContext.CancelOrderCommand, Source={x:Reference OrdersRoot}}"
                                  CommandParameter="{Binding}"/>
                        <MenuItem Header="Delete order…"
                                  Command="{Binding DataContext.DeleteOrderCommand, Source={x:Reference OrdersRoot}}"
                                  CommandParameter="{Binding}"/>
                    </ContextMenu>
                </Border.ContextMenu>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Status accent stripe -->
                    <Border Grid.Column="0" CornerRadius="6,0,0,6"
                            Background="{Binding Status, Converter={conv:OrderStatusToAccentBrushConverter}}"/>

                    <StackPanel Grid.Column="1" Margin="10,8,10,8">
                        <!-- Order # (key) + channel badge -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding OrderNumber, TargetNullValue='(no number)'}"
                                       FontWeight="Bold" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Margin="6,0,0,0" CornerRadius="8" Padding="6,0" BorderThickness="1"
                                    BorderBrush="{DynamicResource MaterialDesign.Brush.Foreground.Light}">
                                <TextBlock Text="{Binding Channel, Converter={conv:SalesChannelDisplayConverter}}"
                                           FontSize="10" Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"/>
                            </Border>
                        </Grid>

                        <TextBlock Text="{Binding CustomerNameDisplay, TargetNullValue=''}" Margin="0,3,0,0"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"/>

                        <TextBlock Margin="0,3,0,0">
                            <Run Text="{Binding LineItemCount, Mode=OneWay}"/><Run Text=" items · "/><Run Text="{Binding LineTotal, Mode=OneWay, StringFormat=C}"/>
                        </TextBlock>

                        <Grid Margin="0,3,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding OrderDate, StringFormat='MMM d, yyyy'}"
                                       FontSize="10" Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"/>
                            <!-- Reconciliation progress (imported orders only) -->
                            <TextBlock Grid.Column="1" FontSize="10"
                                       Visibility="{Binding ImportedItemCount, Converter={conv:NullToVisibilityConverter}}"
                                       Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}">
                                <Run Text="added "/><Run Text="{Binding LineItemCount, Mode=OneWay}"/><Run Text="/"/><Run Text="{Binding ImportedItemCount, Mode=OneWay}"/>
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="400"/>
            <ColumnDefinition x:Name="SplitterColumn" Width="Auto"/>
            <!-- Editor width + visibility are driven from code-behind (ApplyEditorLayout). -->
            <ColumnDefinition x:Name="EditorColumn" Width="0" MinWidth="0"/>
        </Grid.ColumnDefinitions>

        <!-- Board -->
        <DockPanel Grid.Column="0" Margin="0,0,8,0">
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                <ComboBox Width="160" Margin="0,0,8,0"
                          ItemsSource="{Binding Customers}" SelectedItem="{Binding SelectedCustomer}"
                          DisplayMemberPath="Name"/>
                <Button Content="New Order" Command="{Binding NewOrderCommand}" Padding="12,4" Margin="0,0,8,0"/>
                <Button Content="Import from TCGPlayer CSV…" Command="{Binding ImportTcgPlayerCommand}" Padding="12,4"/>
            </StackPanel>

            <!-- Cancelled strip (collapsible, not a drop target) -->
            <Expander DockPanel.Dock="Bottom" Header="Cancelled" Margin="0,8,0,0" IsExpanded="False">
                <ItemsControl ItemsSource="{Binding CancelledOrders}" Margin="4">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                                    Opacity="0.65" CornerRadius="6" Padding="10,6" Margin="0,0,0,6"
                                    MouseLeftButtonUp="Card_Select" Tag="{Binding}">
                                <Border.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Delete order…"
                                                  Command="{Binding DataContext.DeleteOrderCommand, Source={x:Reference OrdersRoot}}"
                                                  CommandParameter="{Binding}"/>
                                    </ContextMenu>
                                </Border.ContextMenu>
                                <StackPanel>
                                    <TextBlock Text="{Binding OrderNumber, TargetNullValue='(no number)'}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding CustomerNameDisplay, TargetNullValue=''}" FontSize="11"
                                               Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Expander>

            <!-- 4 columns -->
            <UniformGrid Rows="1">
                <!-- Created -->
                <DockPanel Margin="3,0">
                    <Border DockPanel.Dock="Top" BorderThickness="0,0,0,2" BorderBrush="#2196F3"
                            Padding="4,2,4,6" Margin="0,0,0,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Created" FontWeight="Bold"/>
                            <Border Grid.Column="1" Background="#2196F3" CornerRadius="9" MinWidth="20" Padding="6,1">
                                <TextBlock Text="{Binding CreatedOrders.Count}" FontSize="11" Foreground="White"
                                           HorizontalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>
                    <ListBox ItemsSource="{Binding CreatedOrders}" AllowDrop="True" Tag="Created"
                             Drop="Column_Drop" DragOver="Column_DragOver"
                             SelectedItem="{Binding SelectedOrder}"
                             Background="Transparent" BorderThickness="0"
                             ItemTemplate="{StaticResource OrderCardTemplate}"
                             ItemContainerStyle="{StaticResource CardItemContainerStyle}"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
                </DockPanel>

                <!-- Packed -->
                <DockPanel Margin="3,0">
                    <Border DockPanel.Dock="Top" BorderThickness="0,0,0,2" BorderBrush="#FF9800"
                            Padding="4,2,4,6" Margin="0,0,0,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Packed" FontWeight="Bold"/>
                            <Border Grid.Column="1" Background="#FF9800" CornerRadius="9" MinWidth="20" Padding="6,1">
                                <TextBlock Text="{Binding PackedOrders.Count}" FontSize="11" Foreground="White"
                                           HorizontalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>
                    <ListBox ItemsSource="{Binding PackedOrders}" AllowDrop="True" Tag="Packed"
                             Drop="Column_Drop" DragOver="Column_DragOver"
                             SelectedItem="{Binding SelectedOrder}"
                             Background="Transparent" BorderThickness="0"
                             ItemTemplate="{StaticResource OrderCardTemplate}"
                             ItemContainerStyle="{StaticResource CardItemContainerStyle}"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
                </DockPanel>

                <!-- Shipped -->
                <DockPanel Margin="3,0">
                    <Border DockPanel.Dock="Top" BorderThickness="0,0,0,2" BorderBrush="#009688"
                            Padding="4,2,4,6" Margin="0,0,0,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Shipped" FontWeight="Bold"/>
                            <Border Grid.Column="1" Background="#009688" CornerRadius="9" MinWidth="20" Padding="6,1">
                                <TextBlock Text="{Binding ShippedOrders.Count}" FontSize="11" Foreground="White"
                                           HorizontalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>
                    <ListBox ItemsSource="{Binding ShippedOrders}" AllowDrop="True" Tag="Shipped"
                             Drop="Column_Drop" DragOver="Column_DragOver"
                             SelectedItem="{Binding SelectedOrder}"
                             Background="Transparent" BorderThickness="0"
                             ItemTemplate="{StaticResource OrderCardTemplate}"
                             ItemContainerStyle="{StaticResource CardItemContainerStyle}"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
                </DockPanel>

                <!-- Completed -->
                <DockPanel Margin="3,0">
                    <Border DockPanel.Dock="Top" BorderThickness="0,0,0,2" BorderBrush="#4CAF50"
                            Padding="4,2,4,6" Margin="0,0,0,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Completed" FontWeight="Bold"/>
                            <Border Grid.Column="1" Background="#4CAF50" CornerRadius="9" MinWidth="20" Padding="6,1">
                                <TextBlock Text="{Binding CompletedOrders.Count}" FontSize="11" Foreground="White"
                                           HorizontalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>
                    <ListBox ItemsSource="{Binding CompletedOrders}" AllowDrop="True" Tag="Completed"
                             Drop="Column_Drop" DragOver="Column_DragOver"
                             SelectedItem="{Binding SelectedOrder}"
                             Background="Transparent" BorderThickness="0"
                             ItemTemplate="{StaticResource OrderCardTemplate}"
                             ItemContainerStyle="{StaticResource CardItemContainerStyle}"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
                </DockPanel>
            </UniformGrid>
        </DockPanel>

        <!-- Resizable divider between board and editor (shown only when the panel is open) -->
        <GridSplitter x:Name="EditorSplitter" Grid.Column="1" Width="6" Visibility="Collapsed"
                      HorizontalAlignment="Center" VerticalAlignment="Stretch"
                      ResizeBehavior="PreviousAndNext" ResizeDirection="Columns"
                      Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                      DragCompleted="EditorSplitter_DragCompleted"/>

        <!-- Editor -->
        <DockPanel x:Name="EditorPanel" Grid.Column="2" Visibility="Collapsed" Margin="6,0,0,0">

            <!-- Panel title + collapse button -->
            <DockPanel DockPanel.Dock="Top" LastChildFill="False" Margin="0,0,0,6">
                <TextBlock DockPanel.Dock="Left" Text="Order details" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button DockPanel.Dock="Right" Content="›" FontSize="15" Padding="8,0" MinWidth="28"
                        Command="{Binding CollapseEditorCommand}" ToolTip="Collapse panel"/>
            </DockPanel>

            <!-- Header fields -->
            <Grid DockPanel.Dock="Top" Margin="0,0,0,8" IsEnabled="{Binding IsEditable}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Order #:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,4,8,4"/>
                <TextBox Grid.Row="0" Grid.Column="1" Margin="0,4,16,4"
                         Text="{Binding SelectedOrder.OrderNumber, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="Tracking #:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,4,8,4"/>
                <TextBox Grid.Row="0" Grid.Column="3" Margin="0,4"
                         Text="{Binding SelectedOrder.TrackingNumber, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Carrier:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,4,8,4"/>
                <TextBox Grid.Row="1" Grid.Column="1" Margin="0,4,16,4"
                         Text="{Binding SelectedOrder.Carrier, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="1" Grid.Column="2" Text="Marketplace fees:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,4,8,4"/>
                <TextBox Grid.Row="1" Grid.Column="3" Margin="0,4"
                         Text="{Binding SelectedOrder.MarketplaceFees, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Shipping cost:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,4,8,4"/>
                <TextBox Grid.Row="2" Grid.Column="1" Margin="0,4,16,4"
                         Text="{Binding SelectedOrder.ShippingCost, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"/>

                <TextBlock Grid.Row="2" Grid.Column="2" Text="Shipping charged to buyer:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,4,8,4"/>
                <TextBox Grid.Row="2" Grid.Column="3" Margin="0,4"
                         Text="{Binding SelectedOrder.ShippingChargedToBuyer, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"/>
            </Grid>

            <!-- Save/Receipt/Export + total + status message -->
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                <Button Content="Save" Command="{Binding SaveOrderCommand}" Padding="12,4" Margin="0,0,8,0"/>
                <Button Content="Print Receipt" Command="{Binding PrintReceiptCommand}" Padding="12,4" Margin="0,0,8,0"/>
                <Button Content="Export PDF" Command="{Binding ExportPdfCommand}" Padding="12,4" Margin="0,0,16,0"/>
                <TextBlock Text="{Binding OrderTotal, StringFormat=C}" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,16,0"/>
                <TextBlock Text="{Binding ReconciliationHint}"
                           Visibility="{Binding HasReconciliation, Converter={conv:BoolToVisibilityConverter}}"
                           VerticalAlignment="Center" Margin="16,0,0,0"
                           Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"/>
                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Add-card row -->
            <DockPanel DockPanel.Dock="Bottom" Margin="0,8,0,0" LastChildFill="True" IsEnabled="{Binding IsEditable}">
                <Button DockPanel.Dock="Right" Content="Add" Command="{Binding AddCardCommand}" Padding="12,4" Margin="8,0,0,0"/>
                <ComboBox ItemsSource="{Binding AvailableCards}"
                          SelectedItem="{Binding SelectedAvailableCard}"
                          IsEditable="True" IsTextSearchEnabled="True" StaysOpenOnEdit="True">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <Run Text="{Binding Name, Mode=OneWay}"/>
                                <Run Text=" — "/>
                                <Run Text="{Binding SetName, Mode=OneWay}"/>
                                <Run Text=" ("/>
                                <Run Text="{Binding Condition, Mode=OneWay}"/>
                                <Run Text=") $"/>
                                <Run Text="{Binding ListedPrice, Mode=OneWay, StringFormat=F2}"/>
                            </TextBlock>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </DockPanel>

            <!-- Lines -->
            <DataGrid ItemsSource="{Binding Lines}" AutoGenerateColumns="False" IsReadOnly="True"
                      IsEnabled="{Binding IsEditable}"
                      Style="{StaticResource {x:Type DataGrid}}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding NameSnapshot}" Width="*"/>
                    <DataGridTextColumn Header="Set" Binding="{Binding SetSnapshot}"/>
                    <DataGridTextColumn Header="Condition" Binding="{Binding ConditionSnapshot}"/>
                    <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}"/>
                    <DataGridTextColumn Header="Price" Binding="{Binding UnitSalePrice, StringFormat=C}"/>
                    <DataGridTemplateColumn Header="">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Remove" Padding="8,2"
                                        Command="{Binding DataContext.RemoveLineCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <!-- Reopen handle, shown at the board's right edge only when the panel is collapsed -->
        <Button x:Name="ExpandHandle" Grid.Column="0" Visibility="Collapsed"
                HorizontalAlignment="Right" VerticalAlignment="Center"
                Width="16" Height="64" Content="‹" FontSize="15" Padding="0"
                Command="{Binding ExpandEditorCommand}" ToolTip="Show order details"/>
    </Grid>
</UserControl>
