<UserControl x:Class="OmniCard.Views.Root.HomeTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:OmniCard.Views.Root"
             xmlns:conv="clr-namespace:OmniCard.Controls.Converters;assembly=OmniCard.Controls"
             xmlns:helpers="clr-namespace:OmniCard.Controls;assembly=OmniCard.Controls"
             xmlns:models="clr-namespace:OmniCard.Models;assembly=OmniCard.Shared"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Loading indicator -->
        <StackPanel Grid.Row="0" Margin="8"
                    Visibility="{Binding ViewModel.IsCalculatingCompletion, Converter={StaticResource BoolToVis}}">
            <ProgressBar IsIndeterminate="True" Height="4" Margin="0,0,0,4"/>
            <TextBlock Text="{Binding ViewModel.CompletionStatusMessage}"
                       Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
        </StackPanel>

        <!-- Collection Stats Dashboard -->
        <Border Grid.Row="1" Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                CornerRadius="4" Padding="12" Margin="8,4,8,4"
                Visibility="{Binding ViewModel.IsCalculatingCompletion, Converter={conv:InverseBoolToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 1: Key stats -->
                <StackPanel Grid.Column="0" HorizontalAlignment="Center" Margin="8,4">
                    <TextBlock Text="{Binding ViewModel.StatTotalCards}" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Total Cards" Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Center" Margin="8,4">
                    <TextBlock Text="{Binding ViewModel.StatTotalSets}" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Sets" Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="2" HorizontalAlignment="Center" Margin="8,4">
                    <TextBlock Text="{Binding ViewModel.StatFoilCount}" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Foils" Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="3" HorizontalAlignment="Center" Margin="8,4">
                    <TextBlock Text="{Binding ViewModel.StatTotalValue, StringFormat='${0:F2}'}" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Total Value" Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Row 2: Rarity breakdown -->
                <StackPanel Grid.Row="1" Grid.ColumnSpan="4" Orientation="Horizontal"
                            HorizontalAlignment="Center" Margin="0,8,0,0">
                    <Border Background="#555555" CornerRadius="3" Padding="8,4" Margin="4,0">
                        <TextBlock><Run Text="{Binding ViewModel.StatCommonCount, Mode=OneWay}"/><Run Text=" Common"/></TextBlock>
                    </Border>
                    <Border Background="#C0C0C0" CornerRadius="3" Padding="8,4" Margin="4,0">
                        <TextBlock Foreground="Black"><Run Text="{Binding ViewModel.StatUncommonCount, Mode=OneWay}"/><Run Text=" Uncommon"/></TextBlock>
                    </Border>
                    <Border Background="#FFD700" CornerRadius="3" Padding="8,4" Margin="4,0">
                        <TextBlock Foreground="Black"><Run Text="{Binding ViewModel.StatRareCount, Mode=OneWay}"/><Run Text=" Rare"/></TextBlock>
                    </Border>
                    <Border Background="#F05030" CornerRadius="3" Padding="8,4" Margin="4,0">
                        <TextBlock><Run Text="{Binding ViewModel.StatMythicCount, Mode=OneWay}"/><Run Text=" Mythic"/></TextBlock>
                    </Border>
                    <Border Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                            BorderBrush="{DynamicResource MaterialDesign.Brush.TextBox.HoverBorder}"
                            BorderThickness="1" CornerRadius="3" Padding="8,4" Margin="4,0"
                            Visibility="{Binding ViewModel.StatOtherRarityCount, Converter={conv:NullToCollapsedConverter}}">
                        <TextBlock><Run Text="{Binding ViewModel.StatOtherRarityCount, Mode=OneWay}"/><Run Text=" Other"/></TextBlock>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Sets in collection -->
        <Grid Grid.Row="2" Margin="8,0,8,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <DockPanel Visibility="{Binding ViewModel.IsCalculatingCompletion, Converter={conv:InverseBoolToVisibilityConverter}}">
                <TextBlock Text="Sets in Collection" FontWeight="SemiBold" FontSize="14" Margin="0,4,0,4"
                           VerticalAlignment="Center"/>
                <Button Command="{Binding ViewModel.RefreshHomeTabCommand}"
                        Style="{StaticResource MaterialDesignIconButton}"
                        ToolTip="Refresh"
                        Width="28" Height="28" Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Left">
                    <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16"/>
                </Button>
            </DockPanel>


            <ListView Grid.Row="1"
                      ItemsSource="{Binding ViewModel.SetCompletionResults}"
                      SelectedItem="{Binding ViewModel.SelectedSetCompletion}"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      HorizontalContentAlignment="Stretch">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem" BasedOn="{StaticResource {x:Type ListViewItem}}">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListView.ItemsPanel>

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="{StaticResource MaterialDesignLightSeparatorBackground}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Width="240"
                                Margin="6"
                                Padding="10,12">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Offset="0" Color="#33FFFFFF"/>
                                    <GradientStop Offset="1" Color="#0DFFFFFF"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel>
                                <!-- [Set Name] ([set code]) -->
                                <TextBlock HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource MaterialDesign.Brush.Primary}">
                                    <Run Text="{Binding SetName, Mode=OneWay}"/><Run Text=" ("/><Run Text="{Binding SetCode, Mode=OneWay}"/><Run Text=")"/>
                                </TextBlock>

                                <!-- Set symbol (MTG) or set code in large font (One Piece) -->
                                <Grid Height="48" Margin="0,10">
                                    <!-- MTG: common-shape SVG tinted light so it reads on the dark tile -->
                                    <Border Width="44" Height="44"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            helpers:SetSymbol.SetCode="{Binding SetCode}"
                                            helpers:SetSymbol.Rarity="common"
                                            helpers:SetSymbol.Tint="#F0F0F0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Game}" Value="{x:Static models:CardGame.Mtg}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>

                                    <!-- One Piece: no symbol, show the set code larger -->
                                    <TextBlock Text="{Binding SetCode}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               TextAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               FontFamily="{StaticResource AppFont}"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Foreground="White">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Game}" Value="{x:Static models:CardGame.OnePiece}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>

                                <!-- [owned] / [total] ([percent]%) — distinct cards toward completion -->
                                <TextBlock Text="{Binding Converter={conv:CompletionPercentConverter}}"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           FontFamily="{StaticResource AppFont}"
                                           Foreground="White"/>

                                <!-- Total physical copies (shown only when duplicates exist) -->
                                <TextBlock Text="{Binding CopiesDisplay}"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="11"
                                           Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
                                           Visibility="{Binding HasDuplicateCopies, Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</UserControl>
