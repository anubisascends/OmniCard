<UserControl x:Class="OmniCard.Views.Root.ScannerDetailPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             xmlns:local="clr-namespace:OmniCard.Views.Root"
             xmlns:conv="clr-namespace:OmniCard.Controls.Converters;assembly=OmniCard.Controls"
             xmlns:controls="clr-namespace:OmniCard.Controls;assembly=OmniCard.Controls"
             xmlns:helpers="clr-namespace:OmniCard.Controls;assembly=OmniCard.Controls">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12"
                    Visibility="{Binding ViewModel.HasSelection, Converter={StaticResource BoolToVis}}">

            <!-- Selection header -->
            <TextBlock FontWeight="SemiBold"
                       FontSize="14"
                       Margin="0,0,0,4">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Text"
                            Value="{Binding ViewModel.SharedMatchName, TargetNullValue='(Multiple cards selected)'}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ViewModel.HasMultiSelection}"
                                     Value="True">
                                <Setter Property="Text">
                                    <Setter.Value>
                                        <MultiBinding StringFormat="{}{0} cards selected">
                                            <Binding Path="ViewModel.SelectionCount"/>
                                        </MultiBinding>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Manual search to reassign -->
            <controls:CardSearchControl x:Name="CardSearch"
                Margin="0,0,0,8"
                SearchQuery="{Binding ViewModel.ManualSearchQuery, Mode=TwoWay}"
                SearchResults="{Binding ViewModel.ManualSearchResults}"
                SelectedResult="{Binding ViewModel.SelectedManualSearchResult, Mode=TwoWay}"
                SearchCommand="{Binding ViewModel.ManualSearchCommand}"
                AssignCommand="{Binding ViewModel.AssignMatchCommand}"
                AssignButtonText="{Binding ViewModel.AssignButtonText}"/>

            <!-- Printing selector (single or multi-select, same card name) -->
            <Border Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                CornerRadius="4" Padding="8" Margin="0,0,0,8"
                Visibility="{Binding ViewModel.ShowPrintingSelector, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold" FontSize="11"
                           Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}" Margin="0,0,0,4">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Printing"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ViewModel.HasMultiSelection}" Value="True">
                                        <Setter Property="Text"
                                            Value="{Binding ViewModel.SelectionCount, StringFormat='Printing ({0} cards)'}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <ComboBox ItemsSource="{Binding ViewModel.AvailablePrintings}"
                          SelectedItem="{Binding ViewModel.SelectedPrinting}"
                          MaxDropDownHeight="300">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <Border Width="{Binding DataContext.ViewModel.CardDetailFontSize,
                                                RelativeSource={RelativeSource AncestorType=Window}}"
                                            Height="{Binding DataContext.ViewModel.CardDetailFontSize,
                                                RelativeSource={RelativeSource AncestorType=Window}}"
                                            Margin="0,0,6,0"
                                            helpers:SetSymbol.SetCode="{Binding SetCode}"
                                            helpers:SetSymbol.Rarity="{Binding Rarity}"/>
                                    <TextBlock Text="{Binding SetName}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding CollectorNumber, StringFormat='#{0}'}"
                                           Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
                                           VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </Border>

            <!-- Bulk edit for multi-selected scanned cards -->
            <Border Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                CornerRadius="4" Padding="8" Margin="0,0,0,8"
                Visibility="{Binding ViewModel.HasMultiSelection, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="Bulk Edit" FontWeight="SemiBold" FontSize="11"
                           Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}" Margin="0,0,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Condition:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ComboBox Grid.Column="1" SelectedItem="{Binding ViewModel.BulkCondition}"
                              VerticalAlignment="Center" Margin="0,0,12,0">
                            <sys:String>NM</sys:String>
                            <sys:String>LP</sys:String>
                            <sys:String>MP</sys:String>
                            <sys:String>HP</sys:String>
                            <sys:String>D</sys:String>
                        </ComboBox>
                        <CheckBox Grid.Column="2" Content="Foil"
                              IsChecked="{Binding ViewModel.BulkIsFoil}"
                              VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBlock Grid.Column="3" Text="Purchase $:" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox Grid.Column="4" Width="80"
                             Text="{Binding ViewModel.BulkPurchasePrice, TargetNullValue='', UpdateSourceTrigger=LostFocus}"
                             VerticalAlignment="Center"/>
                    </Grid>
                    <Button Content="Apply to Selected" Padding="12,4" Margin="0,8,0,0"
                        HorizontalAlignment="Left"
                        Command="{Binding ViewModel.ApplyBulkEditCommand}"/>
                </StackPanel>
            </Border>

            <!-- No match message (any unmatched in selection) -->
            <TextBlock Text="One or more selected cards have no match. Use the search above to assign."
                   FontStyle="Italic"
                   Foreground="OrangeRed"
                   Margin="0,0,0,8"
                   Visibility="{Binding ViewModel.AnyUnmatched, Converter={StaticResource BoolToVis}}"/>

            <!-- Single-select: editable per-scan fields -->
            <Border Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                CornerRadius="4"
                Padding="8"
                Margin="0,0,0,8"
                Visibility="{Binding ViewModel.HasSingleSelection, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Condition:"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"/>
                    <ComboBox Grid.Column="1"
                          SelectedItem="{Binding ViewModel.SelectedScannedCard.Condition}"
                          VerticalAlignment="Center"
                          Margin="0,0,12,0">
                        <sys:String>NM</sys:String>
                        <sys:String>LP</sys:String>
                        <sys:String>MP</sys:String>
                        <sys:String>HP</sys:String>
                        <sys:String>D</sys:String>
                    </ComboBox>

                    <CheckBox Grid.Column="2"
                          Content="Foil"
                          IsChecked="{Binding ViewModel.SelectedScannedCard.IsFoil}"
                          VerticalAlignment="Center"
                          Margin="0,0,12,0"/>

                    <TextBlock Grid.Column="3"
                           Text="Purchase $:"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"/>
                    <TextBox Grid.Column="4"
                         Width="80"
                         Text="{Binding ViewModel.SelectedScannedCard.PurchasePrice,
                                TargetNullValue='', UpdateSourceTrigger=LostFocus}"
                         VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Single-select: per-card location override -->
            <Border Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                CornerRadius="4"
                Padding="8"
                Margin="0,0,0,8"
                Visibility="{Binding ViewModel.HasSingleSelection, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="Location Override"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4"
                           FontSize="11"
                           Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"/>
                    <StackPanel Orientation="Horizontal"
                            Margin="0,0,0,4">
                        <TextBlock Text="Container:"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                        <ComboBox ItemsSource="{Binding ViewModel.AvailableContainers}"
                              SelectedItem="{Binding ViewModel.SelectedScannedCard.OverrideContainer}"
                              DisplayMemberPath="Name"
                              Width="160"
                              VerticalAlignment="Center"
                              Margin="0,0,8,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal"
                            Margin="0,0,0,4"
                            Visibility="{Binding ViewModel.ShowOverrideBinderFields, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Page:"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                        <TextBox Text="{Binding ViewModel.SelectedScannedCard.OverridePage, TargetNullValue='', UpdateSourceTrigger=LostFocus}"
                             Width="50"
                             Margin="0,0,12,0"/>
                        <TextBlock Text="Slot:"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                        <TextBox Text="{Binding ViewModel.SelectedScannedCard.OverrideSlot, TargetNullValue='', UpdateSourceTrigger=LostFocus}"
                             Width="50"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal"
                            Visibility="{Binding ViewModel.ShowOverrideBoxFields, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Section:"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                        <TextBox Text="{Binding ViewModel.SelectedScannedCard.OverrideSection, TargetNullValue='', UpdateSourceTrigger=PropertyChanged}"
                             Width="160"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Single-select: game-specific card detail -->
            <ContentControl Content="{Binding ViewModel.SharedMatchSource}"
                        Visibility="{Binding ViewModel.SharedMatchSource,
                            Converter={conv:NullToCollapsedConverter}}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
