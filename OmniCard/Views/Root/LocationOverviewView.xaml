<UserControl x:Class="OmniCard.Views.Root.LocationOverviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:OmniCard.Views.Root"
             xmlns:conv="clr-namespace:OmniCard.Controls.Converters;assembly=OmniCard.Controls"
             xmlns:models="clr-namespace:OmniCard.Models;assembly=OmniCard.Shared">

    <UserControl.Resources>
        <!-- Location tile template -->
        <DataTemplate x:Key="LocationTileTemplate" DataType="{x:Type models:LocationTileSummary}">
            <Button Command="{Binding DataContext.ViewModel.Collection.NavigateToLocationCommand,
                        RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="{Binding Container.Id}"
                    Cursor="Hand"
                    Margin="4"
                    Style="{x:Null}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="TileBorder"
                                BorderBrush="{StaticResource MaterialDesignLightSeparatorBackground}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Width="240"
                                Padding="10,12"
                                ClipToBounds="True">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Offset="0" Color="#33FFFFFF"/>
                                    <GradientStop Offset="1" Color="#0DFFFFFF"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel>
                                <!-- Location name -->
                                <TextBlock Text="{Binding Container.Name}"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>

                                <!-- Unique Prints: X; Total Cards: Y -->
                                <TextBlock HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="13"
                                           Margin="0,6,0,0"
                                           Foreground="White">
                                    <Run Text="Unique Prints: "/><Run Text="{Binding UniquePrintCount, Mode=OneWay}"/><Run Text="; Total Cards: "/><Run Text="{Binding CardCount, Mode=OneWay}"/>
                                </TextBlock>

                                <!-- Sum of market values -->
                                <TextBlock Text="{Binding TotalMarketValue, StringFormat='${0:N2}'}"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           FontFamily="{StaticResource AppFont}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Margin="0,6,0,0"
                                           Foreground="White"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TileBorder" Property="BorderBrush"
                                        Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
                                <Setter TargetName="TileBorder" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>

                <!-- Context menu -->
                <Button.ContextMenu>
                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                        <MenuItem Header="Change Cover Art..."
                                  Click="ChangeCoverArt_Click"/>
                        <Separator Visibility="{Binding Container.IsSystem, Converter={conv:InverseBoolToVisibilityConverter}}"/>
                        <MenuItem Header="Delete Location..."
                                  Click="DeleteLocation_Click"
                                  Visibility="{Binding Container.IsSystem, Converter={conv:InverseBoolToVisibilityConverter}}"/>
                        <Separator/>
                        <MenuItem Header="Add Card..."
                                  Click="AddCard_Click"/>
                        <Separator/>
                        <MenuItem Header="Audit Location..."
                                  Click="AuditLocation_Click"/>
                        <Separator/>
                        <MenuItem Header="Export to Manabox..."
                                  Click="ExportLocationManabox_Click"/>
                        <Separator/>
                        <MenuItem Header="Exclude from Deck Check"
                                  IsCheckable="True"
                                  IsChecked="{Binding Container.ExcludeFromDeckCheck, Mode=OneWay}"
                                  Click="ToggleDeckCheckExclusion_Click"/>
                    </ContextMenu>
                </Button.ContextMenu>
            </Button>
        </DataTemplate>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12">

            <!-- Browse All link -->
            <Button Content="Browse Entire Collection"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,12"
                    Padding="12,6"
                    Command="{Binding DataContext.ViewModel.Collection.BrowseAllCommand,
                        RelativeSource={RelativeSource AncestorType=Window}}"
                    Style="{StaticResource MaterialDesignFlatButton}"/>

            <!-- Bulk container (same tile style as others) -->
            <WrapPanel Margin="0,0,0,12"
                       Visibility="{Binding DataContext.ViewModel.Collection.IsBulkVisible,
                           RelativeSource={RelativeSource AncestorType=Window},
                           Converter={conv:BoolToVisibilityConverter}}">
                <ContentControl Content="{Binding DataContext.ViewModel.Collection.BulkSummary,
                                    RelativeSource={RelativeSource AncestorType=Window}}"
                                ContentTemplate="{StaticResource LocationTileTemplate}"/>
            </WrapPanel>

            <!-- Grouped containers by type -->
            <ItemsControl ItemsSource="{Binding DataContext.ViewModel.Collection.GroupedLocations,
                                RelativeSource={RelativeSource AncestorType=Window}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Expander Header="{Binding Key, Converter={conv:ContainerTypeDisplayConverter}}"
                                  IsExpanded="True"
                                  Margin="0,0,0,8">
                            <ItemsControl ItemsSource="{Binding}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <StaticResource ResourceKey="LocationTileTemplate"/>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- No matching locations placeholder -->
            <TextBlock Text="No matching locations"
                       HorizontalAlignment="Center"
                       Margin="0,40,0,0"
                       FontSize="18"
                       FontStyle="Italic"
                       Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding DataContext.ViewModel.Collection.IsOverviewSearchActive,
                                        RelativeSource={RelativeSource AncestorType=Window}}" Value="True"/>
                                    <Condition Binding="{Binding DataContext.ViewModel.Collection.HasVisibleLocations,
                                        RelativeSource={RelativeSource AncestorType=Window}}" Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

        </StackPanel>
    </ScrollViewer>
</UserControl>
