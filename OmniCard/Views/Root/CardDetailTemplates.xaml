<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:helpers="clr-namespace:OmniCard.Helpers"
                    xmlns:models="clr-namespace:OmniCard.Models"
                    xmlns:local="clr-namespace:OmniCard.Views.Root">

    <!-- MTG detail template -->
    <DataTemplate DataType="{x:Type models:Card}">
        <StackPanel>
            <TextBlock Text="{Binding Name}"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0,0,0,4"/>
            <RichTextBox helpers:MtgText.Text="{Binding ManaCost}"
                         IsReadOnly="True"
                         BorderThickness="0"
                         Background="Transparent"
                         Padding="-2,0,0,0"
                         Margin="0,0,0,8"
                         FontSize="{Binding DataContext.ViewModel.CardDetailFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                         IsDocumentEnabled="True"
                         IsTabStop="False"
                         Focusable="False">
                <RichTextBox.Resources>
                    <Style TargetType="Paragraph">
                        <Setter Property="Margin"
                                Value="0"/>
                    </Style>
                </RichTextBox.Resources>
            </RichTextBox>

            <Separator Margin="0,4"/>

            <Grid Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <TextBlock Text="Type:"
                           FontWeight="SemiBold"
                           Margin="0,2,8,2"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding TypeLine}"
                           Margin="0,2"
                           TextWrapping="Wrap"/>

                <TextBlock Grid.Row="1"
                           Text="Set:"
                           FontWeight="SemiBold"
                           Margin="0,2,8,2"/>
                <StackPanel Grid.Row="1"
                            Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,2">
                    <Border Width="16"
                            Height="16"
                            Margin="0,0,4,0"
                            helpers:SetSymbol.SetCode="{Binding SetCode}"
                            helpers:SetSymbol.Rarity="{Binding Rarity}"/>
                    <TextBlock VerticalAlignment="Center">
                        <Run Text="{Binding SetName, Mode=OneWay}"/>
                        <Run Text=" ("/><Run Text="{Binding SetCode, Mode=OneWay}"/><Run Text=")"/>
                    </TextBlock>
                </StackPanel>

                <TextBlock Grid.Row="2"
                           Text="Collector #:"
                           FontWeight="SemiBold"
                           Margin="0,2,8,2"/>
                <TextBlock Grid.Row="2"
                           Grid.Column="1"
                           Text="{Binding CollectorNumber}"
                           Margin="0,2"/>

                <TextBlock Grid.Row="3"
                           Text="Rarity:"
                           FontWeight="SemiBold"
                           Margin="0,2,8,2"/>
                <TextBlock Grid.Row="3"
                           Grid.Column="1"
                           Text="{Binding Rarity}"
                           Margin="0,2"/>

                <TextBlock Grid.Row="4"
                           Text="Artist:"
                           FontWeight="SemiBold"
                           Margin="0,2,8,2"/>
                <TextBlock Grid.Row="4"
                           Grid.Column="1"
                           Text="{Binding Artist}"
                           Margin="0,2"/>

                <TextBlock Grid.Row="5"
                           Text="Colors:"
                           FontWeight="SemiBold"
                           Margin="0,2,8,2"/>
                <TextBlock Grid.Row="5"
                           Grid.Column="1"
                           Text="{Binding ColorIdentity, Converter={local:ListToStringConverter}}"
                           Margin="0,2"/>

                <TextBlock Grid.Row="6"
                           Text="CMC:"
                           FontWeight="SemiBold"
                           Margin="0,2,8,2"/>
                <TextBlock Grid.Row="6"
                           Grid.Column="1"
                           Text="{Binding Cmc}"
                           Margin="0,2"/>

                <TextBlock Grid.Row="7"
                           Text="Layout:"
                           FontWeight="SemiBold"
                           Margin="0,2,8,2"/>
                <TextBlock Grid.Row="7"
                           Grid.Column="1"
                           Text="{Binding Layout}"
                           Margin="0,2"/>
            </Grid>

            <Separator Margin="0,4"/>
            <TextBlock Text="Oracle Text"
                       FontWeight="SemiBold"
                       Margin="0,4,0,2"/>
            <RichTextBox helpers:MtgText.Text="{Binding OracleText}"
                         IsReadOnly="True"
                         BorderThickness="0"
                         Background="Transparent"
                         Padding="-2,0,0,0"
                         Margin="0,0,0,8"
                         FontSize="{Binding DataContext.ViewModel.CardDetailFontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                         HorizontalScrollBarVisibility="Disabled"
                         IsDocumentEnabled="True"
                         IsTabStop="False"
                         Focusable="False">
                <RichTextBox.Resources>
                    <Style TargetType="Paragraph">
                        <Setter Property="Margin"
                                Value="0"/>
                    </Style>
                </RichTextBox.Resources>
            </RichTextBox>
            <TextBlock Text="{Binding FlavorText}"
                       FontStyle="Italic"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
                       Margin="0,0,0,8"/>

            <Separator Margin="0,4"/>
            <TextBlock Text="Prices"
                       FontWeight="SemiBold"
                       Margin="0,4,0,2"/>
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <TextBlock Text="USD:"
                           FontWeight="SemiBold"
                           Margin="0,2,8,2"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding Prices.Usd, StringFormat='${0}', TargetNullValue='-'}"
                           Margin="0,2"/>
                <TextBlock Grid.Row="1"
                           Text="USD Foil:"
                           FontWeight="SemiBold"
                           Margin="0,2,8,2"/>
                <TextBlock Grid.Row="1"
                           Grid.Column="1"
                           Text="{Binding Prices.UsdFoil, StringFormat='${0}', TargetNullValue='-'}"
                           Margin="0,2"/>
                <TextBlock Grid.Row="2"
                           Text="EUR:"
                           FontWeight="SemiBold"
                           Margin="0,2,8,2"/>
                <TextBlock Grid.Row="2"
                           Grid.Column="1"
                           Text="{Binding Prices.Eur, StringFormat='${0}', TargetNullValue='-'}"
                           Margin="0,2"/>
            </Grid>

            <Separator Margin="0,4"/>
            <TextBlock Text="Legalities"
                       FontWeight="SemiBold"
                       Margin="0,4,0,2"/>
            <ItemsControl ItemsSource="{Binding Legalities}"
                          Margin="0,2">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,1">
                            <TextBlock Text="{Binding Key}"
                                       FontWeight="SemiBold"
                                       Width="100"/>
                            <TextBlock Text="{Binding Value}"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </DataTemplate>

    <!-- One Piece detail template -->
    <DataTemplate DataType="{x:Type models:OptcgCard}">
        <StackPanel>
            <TextBlock Text="{Binding CardName}"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0,0,0,4"/>
            <TextBlock FontSize="14"
                       Margin="0,0,0,8">
                <Run Text="{Binding CardColor, Mode=OneWay}"/>
                <Run Text=" "/>
                <Run Text="{Binding CardType, Mode=OneWay}"/>
            </TextBlock>

            <Separator Margin="0,4"/>

            <Grid Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <TextBlock Text="Card ID:"
                           FontWeight="SemiBold"
                           Margin="0,2,8,2"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding CardSetId}"
                           Margin="0,2"/>

                <TextBlock Grid.Row="1"
                           Text="Set:"
                           FontWeight="SemiBold"
                           Margin="0,2,8,2"/>
                <TextBlock Grid.Row="1"
                           Grid.Column="1"
                           Margin="0,2">
                    <Run Text="{Binding SetName, Mode=OneWay}"/>
                    <Run Text=" ("/><Run Text="{Binding SetId, Mode=OneWay}"/><Run Text=")"/>
                </TextBlock>

                <TextBlock Grid.Row="2"
                           Text="Rarity:"
                           FontWeight="SemiBold"
                           Margin="0,2,8,2"/>
                <TextBlock Grid.Row="2"
                           Grid.Column="1"
                           Text="{Binding Rarity}"
                           Margin="0,2"/>

                <TextBlock Grid.Row="3"
                           Text="Cost:"
                           FontWeight="SemiBold"
                           Margin="0,2,8,2"/>
                <TextBlock Grid.Row="3"
                           Grid.Column="1"
                           Text="{Binding CardCost, TargetNullValue='-'}"
                           Margin="0,2"/>

                <TextBlock Grid.Row="4"
                           Text="Power:"
                           FontWeight="SemiBold"
                           Margin="0,2,8,2"/>
                <TextBlock Grid.Row="4"
                           Grid.Column="1"
                           Text="{Binding CardPower, TargetNullValue='-'}"
                           Margin="0,2"/>

                <TextBlock Grid.Row="5"
                           Text="Counter:"
                           FontWeight="SemiBold"
                           Margin="0,2,8,2"/>
                <TextBlock Grid.Row="5"
                           Grid.Column="1"
                           Text="{Binding CounterAmount, TargetNullValue='-'}"
                           Margin="0,2"/>

                <TextBlock Grid.Row="6"
                           Text="Life:"
                           FontWeight="SemiBold"
                           Margin="0,2,8,2"/>
                <TextBlock Grid.Row="6"
                           Grid.Column="1"
                           Text="{Binding Life, TargetNullValue='-'}"
                           Margin="0,2"/>

                <TextBlock Grid.Row="7"
                           Text="Attribute:"
                           FontWeight="SemiBold"
                           Margin="0,2,8,2"/>
                <TextBlock Grid.Row="7"
                           Grid.Column="1"
                           Text="{Binding Attribute, TargetNullValue='-'}"
                           Margin="0,2"/>

                <TextBlock Grid.Row="8"
                           Text="Types:"
                           FontWeight="SemiBold"
                           Margin="0,2,8,2"/>
                <TextBlock Grid.Row="8"
                           Grid.Column="1"
                           Text="{Binding SubTypes, TargetNullValue='-'}"
                           Margin="0,2"
                           TextWrapping="Wrap"/>
            </Grid>

            <Separator Margin="0,4"/>
            <TextBlock Text="Card Text"
                       FontWeight="SemiBold"
                       Margin="0,4,0,2"/>
            <TextBlock Text="{Binding CardText}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,8"/>

            <Separator Margin="0,4"/>
            <TextBlock Text="Prices"
                       FontWeight="SemiBold"
                       Margin="0,4,0,2"/>
            <Grid Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <TextBlock Text="Market:"
                           FontWeight="SemiBold"
                           Margin="0,2,8,2"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding MarketPrice, StringFormat='${0:F2}', TargetNullValue='-'}"
                           Margin="0,2"/>
                <TextBlock Grid.Row="1"
                           Text="Inventory:"
                           FontWeight="SemiBold"
                           Margin="0,2,8,2"/>
                <TextBlock Grid.Row="1"
                           Grid.Column="1"
                           Text="{Binding InventoryPrice, StringFormat='${0:F2}', TargetNullValue='-'}"
                           Margin="0,2"/>
            </Grid>
        </StackPanel>
    </DataTemplate>

</ResourceDictionary>
