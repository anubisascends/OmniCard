<UserControl x:Class="OmniCard.Views.Root.CollectionTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:OmniCard.Views.Root">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <!-- Cards / Sealed toggle -->
        <Border Padding="8,4"
                Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                BorderBrush="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <RadioButton Content="Cards" GroupName="CollectionMode"
                             IsChecked="{Binding DataContext.ViewModel.Sealed.ShowSealed,
                                 RelativeSource={RelativeSource AncestorType=Window},
                                 Converter={local:InverseBoolConverter}}"
                             Margin="0,0,12,0"/>
                <RadioButton Content="Sealed Products" GroupName="CollectionMode"
                             IsChecked="{Binding DataContext.ViewModel.Sealed.ShowSealed,
                                 RelativeSource={RelativeSource AncestorType=Window}}"/>
            </StackPanel>
        </Border>

        <!-- Toolbar (visible in card list mode, hidden when showing sealed) -->
        <ToolBarPanel Grid.Row="1">
            <ToolBarPanel.Style>
                <Style TargetType="ToolBarPanel">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding DataContext.ViewModel.Sealed.ShowSealed,
                            RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ToolBarPanel.Style>
            <ToolBarTray>
                <ToolBar>
                    <!-- Back button -->
                    <Button Content="&lt; Back"
                            Command="{Binding DataContext.ViewModel.Collection.NavigateBackCommand,
                                RelativeSource={RelativeSource AncestorType=Window}}"
                            Padding="8,4"
                            Margin="0,0,8,0"
                            Visibility="{Binding DataContext.ViewModel.Collection.ShowCardList,
                                RelativeSource={RelativeSource AncestorType=Window},
                                Converter={local:BoolToVisibilityConverter}}"/>
                    <Separator Visibility="{Binding DataContext.ViewModel.Collection.ShowCardList,
                        RelativeSource={RelativeSource AncestorType=Window},
                        Converter={local:BoolToVisibilityConverter}}"/>

                    <!-- Location name -->
                    <TextBlock Text="{Binding DataContext.ViewModel.Collection.CurrentLocationName,
                                   RelativeSource={RelativeSource AncestorType=Window}}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"
                               Visibility="{Binding DataContext.ViewModel.Collection.ShowCardList,
                                   RelativeSource={RelativeSource AncestorType=Window},
                                   Converter={local:BoolToVisibilityConverter}}"/>
                    <Separator Visibility="{Binding DataContext.ViewModel.Collection.ShowCardList,
                        RelativeSource={RelativeSource AncestorType=Window},
                        Converter={local:BoolToVisibilityConverter}}"/>

                    <!-- Search -->
                    <TextBox x:Name="CollectionSearchBox"
                             Text="{Binding DataContext.ViewModel.Collection.CollectionSearchQuery,
                                 RelativeSource={RelativeSource AncestorType=Window},
                                 UpdateSourceTrigger=PropertyChanged}"
                             Width="200"
                             VerticalContentAlignment="Center"
                             Margin="0,0,4,0">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return"
                                        Command="{Binding DataContext.ViewModel.Collection.SearchCollectionCommand,
                                            RelativeSource={RelativeSource AncestorType=Window}}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button Content="Go"
                            Command="{Binding DataContext.ViewModel.Collection.SearchCollectionCommand,
                                RelativeSource={RelativeSource AncestorType=Window}}"
                            Padding="8,4"/>
                    <Separator Visibility="{Binding DataContext.ViewModel.Collection.ShowCardList,
                        RelativeSource={RelativeSource AncestorType=Window},
                        Converter={local:BoolToVisibilityConverter}}"/>

                    <!-- Sort/Filter presets -->
                    <TextBlock Text="Sort:"
                            VerticalAlignment="Center"
                            Margin="4,0,4,0"
                            Visibility="{Binding DataContext.ViewModel.Collection.ShowCardList,
                                RelativeSource={RelativeSource AncestorType=Window},
                                Converter={local:BoolToVisibilityConverter}}"/>
                    <ComboBox ItemsSource="{Binding DataContext.ViewModel.Collection.AvailableSortPresets,
                                  RelativeSource={RelativeSource AncestorType=Window}}"
                              SelectedItem="{Binding DataContext.ViewModel.Collection.SelectedSortPreset,
                                  RelativeSource={RelativeSource AncestorType=Window}}"
                              DisplayMemberPath="Name"
                              Width="120"
                              VerticalAlignment="Center"
                              Visibility="{Binding DataContext.ViewModel.Collection.ShowCardList,
                                  RelativeSource={RelativeSource AncestorType=Window},
                                  Converter={local:BoolToVisibilityConverter}}"/>
                    <Button Content="X"
                            FontSize="10"
                            Padding="4,2"
                            Command="{Binding DataContext.ViewModel.Collection.ResetSelectedSortPresetCommand,
                                RelativeSource={RelativeSource AncestorType=Window}}"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Visibility="{Binding DataContext.ViewModel.Collection.ShowCardList,
                                RelativeSource={RelativeSource AncestorType=Window},
                                Converter={local:BoolToVisibilityConverter}}"/>

                    <TextBlock Text="Filter:"
                            VerticalAlignment="Center"
                            Margin="4,0,4,0"
                            Visibility="{Binding DataContext.ViewModel.Collection.ShowCardList,
                                RelativeSource={RelativeSource AncestorType=Window},
                                Converter={local:BoolToVisibilityConverter}}"/>
                    <ComboBox ItemsSource="{Binding DataContext.ViewModel.Collection.AvailableFilterPresets,
                                  RelativeSource={RelativeSource AncestorType=Window}}"
                              SelectedItem="{Binding DataContext.ViewModel.Collection.SelectedFilterPreset,
                                  RelativeSource={RelativeSource AncestorType=Window}}"
                              DisplayMemberPath="Name"
                              Width="120"
                              VerticalAlignment="Center"
                              Visibility="{Binding DataContext.ViewModel.Collection.ShowCardList,
                                  RelativeSource={RelativeSource AncestorType=Window},
                                  Converter={local:BoolToVisibilityConverter}}"/>
                    <Button Content="X"
                            FontSize="10"
                            Padding="4,2"
                            Command="{Binding DataContext.ViewModel.Collection.ResetSelectedFilterPresetCommand,
                                RelativeSource={RelativeSource AncestorType=Window}}"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Visibility="{Binding DataContext.ViewModel.Collection.ShowCardList,
                                RelativeSource={RelativeSource AncestorType=Window},
                                Converter={local:BoolToVisibilityConverter}}"/>

                    <Separator Visibility="{Binding DataContext.ViewModel.Collection.ShowCardList,
                        RelativeSource={RelativeSource AncestorType=Window},
                        Converter={local:BoolToVisibilityConverter}}"/>

                    <!-- Stack duplicates toggle -->
                    <CheckBox Content="Stack Duplicates"
                              IsChecked="{Binding DataContext.ViewModel.Collection.IsStacked,
                                      RelativeSource={RelativeSource AncestorType=Window}}"
                              Padding="8,4"
                              Visibility="{Binding DataContext.ViewModel.Collection.ShowCardList,
                                  RelativeSource={RelativeSource AncestorType=Window},
                                  Converter={local:BoolToVisibilityConverter}}"/>

                    <Separator Visibility="{Binding DataContext.ViewModel.Collection.ShowCardList,
                        RelativeSource={RelativeSource AncestorType=Window},
                        Converter={local:BoolToVisibilityConverter}}"/>

                    <!-- Column chooser -->
                    <Button x:Name="ColumnChooserLink"
                            Click="ColumnChooserLink_Click"
                            VerticalAlignment="Center"
                            Margin="4,0"
                            Cursor="Hand"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Padding="4,2"
                            Visibility="{Binding DataContext.ViewModel.Collection.ShowCardList,
                                RelativeSource={RelativeSource AncestorType=Window},
                                Converter={local:BoolToVisibilityConverter}}">
                        <TextBlock TextDecorations="Underline"
                                   Text="Columns"
                                   Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
                    </Button>
                    <Popup x:Name="ColumnChooserPopup"
                           PlacementTarget="{Binding ElementName=ColumnChooserLink}"
                           Placement="Bottom"
                           StaysOpen="False"
                           AllowsTransparency="True"
                           Visibility="{Binding DataContext.ViewModel.Collection.ShowCardList,
                               RelativeSource={RelativeSource AncestorType=Window},
                               Converter={local:BoolToVisibilityConverter}}">
                        <Border Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                                CornerRadius="4"
                                Padding="8"
                                BorderBrush="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}"
                                BorderThickness="1">
                            <ItemsControl x:Name="ColumnChooserList"/>
                        </Border>
                    </Popup>
                </ToolBar>
            </ToolBarTray>
        </ToolBarPanel>

        <!-- Stats bar (visible in card list mode, hidden when showing sealed) -->
        <Border Grid.Row="2"
                Padding="8,4"
                Background="{DynamicResource MaterialDesign.Brush.Card.Background}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="{Binding DataContext.ViewModel.Collection.ShowCardList,
                        RelativeSource={RelativeSource AncestorType=Window},
                        Converter={local:BoolToVisibilityConverter}}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding DataContext.ViewModel.Sealed.ShowSealed,
                            RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel Orientation="Horizontal">
                <TextBlock Margin="0,0,20,0">
                    <Run Text="Cards:"
                            FontWeight="SemiBold"/>
                    <Run Text="{Binding DataContext.ViewModel.Collection.FilteredCardCount,
                             RelativeSource={RelativeSource AncestorType=Window}, Mode=OneWay}"/>
                </TextBlock>
                <TextBlock Margin="0,0,20,0">
                    <Run Text="Value:"
                            FontWeight="SemiBold"/>
                    <Run Text="{Binding DataContext.ViewModel.Collection.FilteredMarketValue,
                             RelativeSource={RelativeSource AncestorType=Window},
                             StringFormat='${0:N2}', Mode=OneWay}"/>
                </TextBlock>
                <TextBlock>
                    <Run Text="Selected:"
                            FontWeight="SemiBold"/>
                    <Run Text="{Binding DataContext.ViewModel.Collection.SelectedCardCount,
                             RelativeSource={RelativeSource AncestorType=Window}, Mode=OneWay}"/>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Content area -->
        <Grid Grid.Row="3">
            <!-- Location overview (tile grid) — hidden when showing sealed -->
            <local:LocationOverviewView>
                <local:LocationOverviewView.Style>
                    <Style TargetType="local:LocationOverviewView">
                        <Setter Property="Visibility" Value="{Binding DataContext.ViewModel.Collection.ShowCardList,
                            RelativeSource={RelativeSource AncestorType=Window},
                            Converter={local:InverseBoolToVisibilityConverter}}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DataContext.ViewModel.Sealed.ShowSealed,
                                RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </local:LocationOverviewView.Style>
            </local:LocationOverviewView>

            <!-- Card list — hidden when showing sealed -->
            <local:CardListView x:Name="CardList">
                <local:CardListView.Style>
                    <Style TargetType="local:CardListView">
                        <Setter Property="Visibility" Value="{Binding DataContext.ViewModel.Collection.ShowCardList,
                            RelativeSource={RelativeSource AncestorType=Window},
                            Converter={local:BoolToVisibilityConverter}}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DataContext.ViewModel.Sealed.ShowSealed,
                                RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </local:CardListView.Style>
            </local:CardListView>

            <!-- No cards found placeholder — hidden when showing sealed -->
            <TextBlock Text="No Cards Found"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="18"
                       FontStyle="Italic"
                       Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding DataContext.ViewModel.Collection.ShowCardList,
                                        RelativeSource={RelativeSource AncestorType=Window}}" Value="True"/>
                                    <Condition Binding="{Binding DataContext.ViewModel.Collection.FilteredCardCount,
                                        RelativeSource={RelativeSource AncestorType=Window}}" Value="0"/>
                                    <Condition Binding="{Binding DataContext.ViewModel.Sealed.ShowSealed,
                                        RelativeSource={RelativeSource AncestorType=Window}}" Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Sealed products view -->
            <local:SealedProductListView x:Name="SealedList"
                Visibility="{Binding DataContext.ViewModel.Sealed.ShowSealed,
                    RelativeSource={RelativeSource AncestorType=Window},
                    Converter={local:BoolToVisibilityConverter}}"/>
        </Grid>
    </Grid>
</UserControl>
