<UserControl x:Class="OmniCard.Views.Root.CollectionTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:OmniCard.Views.Root"
             xmlns:conv="clr-namespace:OmniCard.Controls.Converters;assembly=OmniCard.Controls">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar (card-list-only controls hidden in overview mode) -->
        <ToolBarPanel Grid.Row="1">
            <ToolBarTray>
                <ToolBar>
                    <!-- Back button -->
                    <Button Content="&lt; Back"
                            Command="{Binding DataContext.ViewModel.Collection.NavigateBackCommand,
                                RelativeSource={RelativeSource AncestorType=Window}}"
                            Padding="8,4"
                            Margin="0,0,8,0"
                            Visibility="{Binding DataContext.ViewModel.Collection.ShowCardList,
                                RelativeSource={RelativeSource AncestorType=Window},
                                Converter={conv:BoolToVisibilityConverter}}"/>
                    <Separator Visibility="{Binding DataContext.ViewModel.Collection.ShowCardList,
                        RelativeSource={RelativeSource AncestorType=Window},
                        Converter={conv:BoolToVisibilityConverter}}"/>

                    <!-- Location name -->
                    <TextBlock Text="{Binding DataContext.ViewModel.Collection.CurrentLocationName,
                                   RelativeSource={RelativeSource AncestorType=Window}}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"
                               Visibility="{Binding DataContext.ViewModel.Collection.ShowCardList,
                                   RelativeSource={RelativeSource AncestorType=Window},
                                   Converter={conv:BoolToVisibilityConverter}}"/>
                    <Separator Visibility="{Binding DataContext.ViewModel.Collection.ShowCardList,
                        RelativeSource={RelativeSource AncestorType=Window},
                        Converter={conv:BoolToVisibilityConverter}}"/>

                    <!-- Audit button (single location only) -->
                    <Button Content="Audit"
                            Command="{Binding DataContext.ViewModel.StartAuditCommand,
                                RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding DataContext.ViewModel.Collection.CurrentLocationId,
                                RelativeSource={RelativeSource AncestorType=Window}}"
                            Padding="8,4"
                            Margin="4,0,0,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Visibility" Value="{Binding DataContext.ViewModel.Collection.ShowCardList,
                                    RelativeSource={RelativeSource AncestorType=Window},
                                    Converter={conv:BoolToVisibilityConverter}}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.ViewModel.Collection.ShowAllCards,
                                        RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Add card manually -->
                    <Button Content="Add Card"
                            Command="{Binding DataContext.ViewModel.Collection.OpenManualAddCommand,
                                RelativeSource={RelativeSource AncestorType=Window}}"
                            Padding="8,4"
                            Margin="4,0,0,0"
                            ToolTip="Search and add a card without scanning"/>
                    <Separator/>

                    <!-- Search -->
                    <TextBox x:Name="CollectionSearchBox"
                             Text="{Binding DataContext.ViewModel.Collection.CollectionSearchQuery,
                                 RelativeSource={RelativeSource AncestorType=Window},
                                 UpdateSourceTrigger=PropertyChanged}"
                             Width="200"
                             VerticalContentAlignment="Center"
                             Margin="0,0,4,0">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return"
                                        Command="{Binding DataContext.ViewModel.Collection.SearchCollectionCommand,
                                            RelativeSource={RelativeSource AncestorType=Window}}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button Content="Go"
                            Command="{Binding DataContext.ViewModel.Collection.SearchCollectionCommand,
                                RelativeSource={RelativeSource AncestorType=Window}}"
                            Padding="8,4"/>
                    <Separator Visibility="{Binding DataContext.ViewModel.Collection.ShowCardList,
                        RelativeSource={RelativeSource AncestorType=Window},
                        Converter={conv:BoolToVisibilityConverter}}"/>

                    <!-- Sort/Filter presets -->
                    <TextBlock Text="Sort:"
                            VerticalAlignment="Center"
                            Margin="4,0,4,0"
                            Visibility="{Binding DataContext.ViewModel.Collection.ShowCardList,
                                RelativeSource={RelativeSource AncestorType=Window},
                                Converter={conv:BoolToVisibilityConverter}}"/>
                    <ComboBox ItemsSource="{Binding DataContext.ViewModel.Collection.AvailableSortPresets,
                                  RelativeSource={RelativeSource AncestorType=Window}}"
                              SelectedItem="{Binding DataContext.ViewModel.Collection.SelectedSortPreset,
                                  RelativeSource={RelativeSource AncestorType=Window}}"
                              DisplayMemberPath="Name"
                              Width="120"
                              VerticalAlignment="Center"
                              Visibility="{Binding DataContext.ViewModel.Collection.ShowCardList,
                                  RelativeSource={RelativeSource AncestorType=Window},
                                  Converter={conv:BoolToVisibilityConverter}}"/>
                    <Button Content="X"
                            FontSize="10"
                            Padding="4,2"
                            Command="{Binding DataContext.ViewModel.Collection.ResetSelectedSortPresetCommand,
                                RelativeSource={RelativeSource AncestorType=Window}}"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Visibility="{Binding DataContext.ViewModel.Collection.ShowCardList,
                                RelativeSource={RelativeSource AncestorType=Window},
                                Converter={conv:BoolToVisibilityConverter}}"/>

                    <TextBlock Text="Filter:"
                            VerticalAlignment="Center"
                            Margin="4,0,4,0"
                            Visibility="{Binding DataContext.ViewModel.Collection.ShowCardList,
                                RelativeSource={RelativeSource AncestorType=Window},
                                Converter={conv:BoolToVisibilityConverter}}"/>
                    <ComboBox ItemsSource="{Binding DataContext.ViewModel.Collection.AvailableFilterPresets,
                                  RelativeSource={RelativeSource AncestorType=Window}}"
                              SelectedItem="{Binding DataContext.ViewModel.Collection.SelectedFilterPreset,
                                  RelativeSource={RelativeSource AncestorType=Window}}"
                              DisplayMemberPath="Name"
                              Width="120"
                              VerticalAlignment="Center"
                              Visibility="{Binding DataContext.ViewModel.Collection.ShowCardList,
                                  RelativeSource={RelativeSource AncestorType=Window},
                                  Converter={conv:BoolToVisibilityConverter}}"/>
                    <Button Content="X"
                            FontSize="10"
                            Padding="4,2"
                            Command="{Binding DataContext.ViewModel.Collection.ResetSelectedFilterPresetCommand,
                                RelativeSource={RelativeSource AncestorType=Window}}"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Visibility="{Binding DataContext.ViewModel.Collection.ShowCardList,
                                RelativeSource={RelativeSource AncestorType=Window},
                                Converter={conv:BoolToVisibilityConverter}}"/>

                    <Separator Visibility="{Binding DataContext.ViewModel.Collection.ShowCardList,
                        RelativeSource={RelativeSource AncestorType=Window},
                        Converter={conv:BoolToVisibilityConverter}}"/>

                    <!-- Stack duplicates toggle -->
                    <CheckBox Content="Stack Duplicates"
                              IsChecked="{Binding DataContext.ViewModel.Collection.IsStacked,
                                      RelativeSource={RelativeSource AncestorType=Window}}"
                              Padding="8,4"
                              Visibility="{Binding DataContext.ViewModel.Collection.ShowCardList,
                                  RelativeSource={RelativeSource AncestorType=Window},
                                  Converter={conv:BoolToVisibilityConverter}}"/>

                </ToolBar>
            </ToolBarTray>
        </ToolBarPanel>

        <!-- Stats bar (visible in card list mode) -->
        <Border Grid.Row="2"
                Padding="8,4"
                Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                Visibility="{Binding DataContext.ViewModel.Collection.ShowCardList,
                    RelativeSource={RelativeSource AncestorType=Window},
                    Converter={conv:BoolToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Margin="0,0,20,0">
                    <Run Text="Cards:"
                            FontWeight="SemiBold"/>
                    <Run Text="{Binding DataContext.ViewModel.Collection.FilteredCardCount,
                             RelativeSource={RelativeSource AncestorType=Window}, Mode=OneWay}"/>
                </TextBlock>
                <TextBlock Margin="0,0,20,0">
                    <Run Text="Value:"
                            FontWeight="SemiBold"/>
                    <Run Text="{Binding DataContext.ViewModel.Collection.FilteredMarketValue,
                             RelativeSource={RelativeSource AncestorType=Window},
                             StringFormat='${0:N2}', Mode=OneWay}"/>
                </TextBlock>
                <TextBlock>
                    <Run Text="Selected:"
                            FontWeight="SemiBold"/>
                    <Run Text="{Binding DataContext.ViewModel.Collection.SelectedCardCount,
                             RelativeSource={RelativeSource AncestorType=Window}, Mode=OneWay}"/>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Content area -->
        <Grid Grid.Row="3">
            <!-- Location overview (tile grid) -->
            <local:LocationOverviewView
                Visibility="{Binding DataContext.ViewModel.Collection.ShowCardList,
                    RelativeSource={RelativeSource AncestorType=Window},
                    Converter={conv:InverseBoolToVisibilityConverter}}"/>

            <!-- Card list -->
            <local:CardListView x:Name="CardList"
                Visibility="{Binding DataContext.ViewModel.Collection.ShowCardList,
                    RelativeSource={RelativeSource AncestorType=Window},
                    Converter={conv:BoolToVisibilityConverter}}"/>

            <!-- No cards found placeholder -->
            <TextBlock Text="No Cards Found"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="18"
                       FontStyle="Italic"
                       Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding DataContext.ViewModel.Collection.ShowCardList,
                                        RelativeSource={RelativeSource AncestorType=Window}}" Value="True"/>
                                    <Condition Binding="{Binding DataContext.ViewModel.Collection.FilteredCardCount,
                                        RelativeSource={RelativeSource AncestorType=Window}}" Value="0"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>
    </Grid>
</UserControl>
