<Window x:Class="OmniCard.Views.StorageManager.StorageManagerView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OmniCard.Views.StorageManager"
        xmlns:models="clr-namespace:OmniCard.Models;assembly=OmniCard.Shared"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance {x:Type local:StorageManagerView}}"
        Title="Manage Storage Locations" Height="600" Width="500"
        MinHeight="400" MinWidth="400"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        FontFamily="{StaticResource AppFont}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:NullToVisibilityConverter x:Key="NullToCollapsed"/>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Container list -->
        <ListBox ItemsSource="{Binding ViewModel.GroupedContainers}"
                 SelectedItem="{Binding ViewModel.SelectedContainer}"
                 Margin="0,0,0,8"
                 VirtualizingStackPanel.IsVirtualizing="False"
                 VirtualizingStackPanel.ScrollUnit="Pixel"
                 ScrollViewer.CanContentScroll="False"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.GroupStyle>
                <GroupStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
                                       Margin="4,8,0,4"/>
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                    <GroupStyle.Panel>
                        <ItemsPanelTemplate>
                            <StackPanel/>
                        </ItemsPanelTemplate>
                    </GroupStyle.Panel>
                </GroupStyle>
            </ListBox.GroupStyle>
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="4,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding TypeDisplay}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="{Binding CardCount}" VerticalAlignment="Center"/>
                        <Button Grid.Column="3" Content="QR" ToolTip="Copy barcode text to clipboard"
                                Command="{Binding DataContext.ViewModel.CopyQrTextCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding Id}"
                                Padding="6,1" FontSize="10"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Action buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="Add" Command="{Binding ViewModel.ShowAddCommand}" Padding="12,4" Margin="0,0,8,0"/>
            <Button Content="Rename" Command="{Binding ViewModel.ShowEditCommand}" Padding="12,4" Margin="0,0,8,0"
                    IsEnabled="{Binding ViewModel.CanEdit}"/>
            <Button Content="Delete" Command="{Binding ViewModel.DeleteSelectedCommand}" Padding="12,4"
                    IsEnabled="{Binding ViewModel.CanDelete}"/>
        </StackPanel>

        <!-- Web app base URL -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,4,0,8">
            <TextBlock Text="Web App URL:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox Text="{Binding ViewModel.BaseUrl, UpdateSourceTrigger=PropertyChanged}"
                     Width="260" VerticalAlignment="Center" FontSize="11"/>
            <Button Content="Use My IP" Command="{Binding ViewModel.UseMyIpCommand}"
                    Padding="8,2" Margin="4,0,0,0" FontSize="11"
                    ToolTip="Set URL to this computer's IP address"
                    Style="{StaticResource MaterialDesignFlatButton}"/>
        </StackPanel>

        <!-- Add panel -->
        <Border Grid.Row="3" Background="{DynamicResource MaterialDesign.Brush.Card.Background}" CornerRadius="4" Padding="8" Margin="0,0,0,8"
                Visibility="{Binding ViewModel.IsAdding, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Text="Add New Container" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="Name:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Text="{Binding ViewModel.NewContainerName, UpdateSourceTrigger=PropertyChanged}"
                             Width="180" Margin="0,0,8,0"/>
                    <TextBlock Text="Type:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox SelectedItem="{Binding ViewModel.NewContainerType}" Width="120"
                              ItemsSource="{Binding Source={x:Static local:StorageManagerView.ContainerTypes}}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Create" Command="{Binding ViewModel.ConfirmAddCommand}" Padding="8,2" Margin="0,0,4,0"/>
                    <Button Content="Cancel" Command="{Binding ViewModel.CancelAddCommand}" Padding="8,2"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Edit panel -->
        <Border Grid.Row="3" Background="{DynamicResource MaterialDesign.Brush.Card.Background}" CornerRadius="4" Padding="8" Margin="0,0,0,8"
                Visibility="{Binding ViewModel.IsEditing, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Text="Rename Container" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="New Name:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Text="{Binding ViewModel.EditName, UpdateSourceTrigger=PropertyChanged}" Width="200"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Save" Command="{Binding ViewModel.ConfirmEditCommand}" Padding="8,2" Margin="0,0,4,0"/>
                    <Button Content="Cancel" Command="{Binding ViewModel.CancelEditCommand}" Padding="8,2"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Close button -->
        <Button Grid.Row="4" Content="Close" Command="{Binding ViewModel.CloseCommand}"
                HorizontalAlignment="Right" Padding="16,4"/>
    </Grid>
</Window>
