<Window x:Class="OmniCard.Views.SortFilterBuilder.SortFilterBuilderView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OmniCard.Views.SortFilterBuilder"
        xmlns:models="clr-namespace:OmniCard.Models"
        xmlns:helpers="clr-namespace:OmniCard.Helpers"
        mc:Ignorable="d"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        d:DataContext="{d:DesignInstance {x:Type local:SortFilterBuilderView}}"
        Title="Sort &amp; Filter Builder"
        Width="680" Height="520"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        FontFamily="{StaticResource AppFont}">

    <Window.Resources>
        <helpers:ListToCommaSeparatedConverter x:Key="ListToCommaSeparatedConverter"/>
    </Window.Resources>

    <Grid>
    <TabControl Margin="8">
        <!-- Sort Tab -->
        <TabItem Header="Sort">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Preset selector -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Preset:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox ItemsSource="{Binding ViewModel.SortPresets}"
                              SelectedItem="{Binding ViewModel.SelectedSortPreset}"
                              DisplayMemberPath="Name"
                              Width="200" Margin="0,0,8,0"/>
                    <TextBox Text="{Binding ViewModel.SortPresetName, UpdateSourceTrigger=PropertyChanged}"
                             Width="200" Margin="0,0,8,0"
                             VerticalContentAlignment="Center"/>
                </StackPanel>

                <!-- Add level button -->
                <Button Grid.Row="1" Content="Add Sort Level"
                        Command="{Binding ViewModel.AddSortLevelCommand}"
                        HorizontalAlignment="Left" Padding="12,4" Margin="0,0,0,8"/>

                <!-- Sort levels list -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding ViewModel.EditingSortLevels}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:SortLevel}">
                                <Border BorderBrush="{DynamicResource MaterialDesign.Brush.DataGrid.ColumnHeader.Border}"
                                        BorderThickness="0,0,0,1" Padding="4" Margin="0,0,0,4">
                                    <StackPanel Orientation="Horizontal">
                                        <ComboBox ItemsSource="{Binding DataContext.ViewModel.AvailableFields, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  SelectedItem="{Binding Field}"
                                                  Width="130" Margin="0,0,8,0"/>
                                        <ComboBox SelectedItem="{Binding Direction}" Width="110" Margin="0,0,8,0">
                                            <models:SortDirection>Ascending</models:SortDirection>
                                            <models:SortDirection>Descending</models:SortDirection>
                                        </ComboBox>
                                        <TextBox Text="{Binding CustomOrder, Converter={StaticResource ListToCommaSeparatedConverter}, UpdateSourceTrigger=LostFocus}"
                                                 Width="150" Margin="0,0,4,0"
                                                 ToolTip="Custom order: comma-separated values (e.g. W,U,B,R,G,Multi,Land,Colorless)"
                                                 VerticalContentAlignment="Center"/>
                                        <Button Content="Fill" Padding="6,2" Margin="0,0,8,0"
                                                ToolTip="Fill with distinct values from your collection"
                                                Command="{Binding DataContext.ViewModel.FillSortCustomOrderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Content="^" Padding="6,2" Margin="0,0,2,0"
                                                Command="{Binding DataContext.ViewModel.MoveSortLevelUpCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Content="v" Padding="6,2" Margin="0,0,2,0"
                                                Command="{Binding DataContext.ViewModel.MoveSortLevelDownCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Content="X" Padding="6,2"
                                                Command="{Binding DataContext.ViewModel.RemoveSortLevelCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Save/Delete buttons -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button Content="Save" Padding="16,6" Margin="0,0,8,0"
                            Command="{Binding ViewModel.SaveSortPresetCommand}"/>
                    <Button Content="Delete" Padding="16,6"
                            Command="{Binding ViewModel.DeleteSortPresetCommand}"/>
                </StackPanel>
            </Grid>
        </TabItem>

        <!-- Filter Tab -->
        <TabItem Header="Filter">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Preset selector -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Preset:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox ItemsSource="{Binding ViewModel.FilterPresets}"
                              SelectedItem="{Binding ViewModel.SelectedFilterPreset}"
                              DisplayMemberPath="Name"
                              Width="200" Margin="0,0,8,0"/>
                    <TextBox Text="{Binding ViewModel.FilterPresetName, UpdateSourceTrigger=PropertyChanged}"
                             Width="200" Margin="0,0,8,0"
                             VerticalContentAlignment="Center"/>
                </StackPanel>

                <!-- Scryfall query -->
                <StackPanel Grid.Row="1">
                    <TextBlock Text="Filter Query (Scryfall syntax):" Margin="0,0,0,4"
                               FontWeight="SemiBold"/>
                    <TextBox Text="{Binding ViewModel.FilterQuery, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="False"
                             FontFamily="Consolas"
                             VerticalContentAlignment="Center"
                             Margin="0,0,0,8"/>
                </StackPanel>

                <!-- Syntax help -->
                <Border Grid.Row="2" Padding="8"
                        Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                        CornerRadius="4">
                    <TextBlock TextWrapping="Wrap" FontSize="12"
                               Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}">
                        <Run FontWeight="SemiBold">Syntax:</Run><LineBreak/>
                        <Run>name: or n:</Run> <Run FontStyle="Italic">card name</Run><LineBreak/>
                        <Run>set: or s:</Run> <Run FontStyle="Italic">set code or name</Run><LineBreak/>
                        <Run>type: or t:</Run> <Run FontStyle="Italic">card type</Run><LineBreak/>
                        <Run>color: or c:</Run> <Run FontStyle="Italic">color (w/u/b/r/g)</Run><LineBreak/>
                        <Run>rarity: or r:</Run> <Run FontStyle="Italic">common/uncommon/rare/mythic</Run><LineBreak/>
                        <Run>cn:</Run> <Run FontStyle="Italic">collector number</Run><LineBreak/>
                        <Run>foil:</Run> <Run FontStyle="Italic">true/false</Run><LineBreak/>
                        <Run>condition:</Run> <Run FontStyle="Italic">NM/LP/MP/HP/D</Run><LineBreak/>
                        <Run>location:</Run> <Run FontStyle="Italic">container name</Run><LineBreak/>
                        <LineBreak/>
                        <Run FontStyle="Italic">Multiple terms are ANDed. Use quotes for multi-word values: name:"lightning bolt"</Run>
                    </TextBlock>
                </Border>

                <!-- Save/Delete buttons -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button Content="Save" Padding="16,6" Margin="0,0,8,0"
                            Command="{Binding ViewModel.SaveFilterPresetCommand}"/>
                    <Button Content="Delete" Padding="16,6"
                            Command="{Binding ViewModel.DeleteFilterPresetCommand}"/>
                </StackPanel>
            </Grid>
        </TabItem>
    </TabControl>
    </Grid>
</Window>
