<UserControl x:Class="OmniCard.Controls.CardSearchControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:OmniCard.Controls.Converters"
             xmlns:ctrl="clr-namespace:OmniCard.Controls"
             x:Name="Self">

    <Border Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
            CornerRadius="4"
            Padding="8">
        <StackPanel>
            <TextBlock Text="{Binding Header, ElementName=Self}"
                       FontWeight="SemiBold"
                       FontSize="13"
                       Margin="0,0,0,4"/>
            <StackPanel Orientation="Horizontal"
                        Margin="0,0,0,4">
                <TextBox x:Name="SearchBox"
                         Text="{Binding SearchQuery, ElementName=Self, UpdateSourceTrigger=PropertyChanged}"
                         Width="250"
                         VerticalContentAlignment="Center"
                         Margin="0,0,8,0"
                         KeyDown="SearchBox_KeyDown"/>
                <Button Command="{Binding SearchCommand, ElementName=Self}"
                        Padding="12,4">Search</Button>
            </StackPanel>
            <ListView ItemsSource="{Binding SearchResults, ElementName=Self}"
                      SelectedItem="{Binding SelectedResult, ElementName=Self}"
                      MaxHeight="{Binding ResultsMaxHeight, ElementName=Self}"
                      Margin="0,0,0,4"
                      MouseDoubleClick="SearchResults_MouseDoubleClick">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="2">
                            <Image Source="{Binding ImageUri}" Width="40" Height="56"
                                   Stretch="Uniform" Margin="0,0,8,0"
                                   Visibility="{Binding ImageUri, Converter={conv:NullToCollapsedConverter}}"/>
                            <StackPanel VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding CollectorNumber}"
                                               Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="14" Height="14" Margin="0,0,4,0"
                                            ctrl:SetSymbol.SetCode="{Binding SetCode}"
                                            ctrl:SetSymbol.Rarity="{Binding Rarity}"/>
                                    <TextBlock Text="{Binding SetName}"
                                               Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <Button Command="{Binding AssignCommand, ElementName=Self}"
                    Content="{Binding AssignButtonText, ElementName=Self}"
                    Padding="12,4"
                    HorizontalAlignment="Left"/>
        </StackPanel>
    </Border>
</UserControl>
